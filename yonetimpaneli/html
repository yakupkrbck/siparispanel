function playAlarm(){ 
    const settings = getNotifSettings();
    if(!settings.newOrderEnabled) return;
    cancelAlarm.pause(); cancelAlarm.currentTime=0;
    const newSrc = settings.newOrderSound;
    alarm.loop = settings.loop;
    alarm.volume = settings.volume;

    const doPlay = () => {
        alarm.play().catch(e => {
            // Autoplay engellendi — 500ms sonra tekrar dene
            console.log('Ses engellendi, tekrar deneniyor...');
            setTimeout(() => alarm.play().catch(()=>{}), 500);
        });
    };

    if(alarm.src !== newSrc && newSrc) {
        alarm.src = newSrc;
        alarm.load();
        alarm.addEventListener('canplay', doPlay, {once:true});
    } else {
        alarm.currentTime=0; doPlay();
    }
}
window.stopAlarm=()=>{ alarm.pause(); alarm.currentTime=0; cancelAlarm.pause(); cancelAlarm.currentTime=0; };

