// Dinamik CSS oluşturucu — printOrd ve printTestReceipt bunu kullanır
function buildPrintCSS(s) {
  const w  = parseInt(s.width  || '76');
  const m  = parseInt(s.margin || '2');
  const lh = s.lineheight || '1.55';
  const font = s.font || "'Courier New',Courier,monospace";
  const fs = parseInt(s.fontsize || '12');
  const iw = s.itemweight || '700';
  const ts = s.totalsize  || '15';
  const bs = s.brandsize  || '17';
  const infoWeight  = s.boldInfo ? '700' : '400';
  const totalBorder = s.darkTotal !== false ? '2px solid #000' : '1px dashed #000';
  // Sağa kayma düzeltmesi:
  // 1. @page margin sıfır + size yazıcı genişliğine göre
  // 2. body width px bazlı (mm bazlı size ile çakışmayı önler)
  // 3. margin:0 left-align garantisi
  const bodyWidthPx = Math.round(w * 3.7795); // 1mm ≈ 3.7795px
  return `
    *{margin:0;padding:0;box-sizing:border-box;}
    @page{margin:0;size:${w+4}mm auto;}
    html{margin:0;padding:0;}
    body{
      font-family:${font};
      font-size:${fs}px;
      width:${bodyWidthPx}px;
      max-width:${bodyWidthPx}px;
      margin:0;
      padding:${m}mm ${m+2}mm ${m}mm ${m}mm;
      color:#000;
      line-height:${lh};
      -webkit-print-color-adjust:exact;
      print-color-adjust:exact;
      overflow:hidden;
    }
    .center{text-align:center;}
    .brand{text-align:center;font-size:${bs}px;font-weight:900;letter-spacing:1px;padding:4px 0 2px;}
    .sub{text-align:center;font-size:10px;letter-spacing:1px;margin-bottom:3px;}
    .sep{border:none;border-top:1px dashed #000;margin:4px 0;}
    .sep2{border:none;border-top:${totalBorder};margin:5px 0;}
    .info{font-size:${Math.max(10,fs-1)}px;line-height:1.75;word-break:break-word;white-space:pre-wrap;font-weight:${infoWeight};}
    .info b{font-weight:900;}
    .rrow{width:100%;display:table;table-layout:fixed;font-size:${fs}px;font-weight:${iw};padding:3px 0;border-bottom:1px dashed #ccc;}
    .rrow .rcell-name{display:table-cell;word-break:break-word;overflow-wrap:break-word;padding-right:4px;}
    .rrow .rcell-price{display:table-cell;width:40px;min-width:40px;text-align:right;white-space:nowrap;font-variant-numeric:tabular-nums;}
    .note-line{font-size:${Math.max(9,fs-2)}px;color:#000;padding:1px 0 3px 8px;font-weight:700;word-break:break-word;letter-spacing:0.3px;}
    .rtot{width:100%;display:table;table-layout:fixed;font-size:${ts}px;font-weight:900;padding:5px 0;}
    .rtot .rcell-name{display:table-cell;word-break:break-word;}
    .rtot .rcell-price{display:table-cell;width:50px;text-align:right;white-space:nowrap;}
    .footer{text-align:center;font-size:${Math.max(9,fs-2)}px;font-weight:600;margin-top:8px;line-height:1.8;}
    .tag{text-align:center;font-size:${Math.max(9,fs-2)}px;font-weight:800;letter-spacing:2px;padding:2px 0;}
    .test-badge{text-align:center;font-size:11px;font-weight:800;border:2px dashed #000;padding:4px;margin:8px 0;letter-spacing:1px;}
  `;
}

