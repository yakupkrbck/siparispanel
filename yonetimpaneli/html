async function loadCourierPanel(){
  document.getElementById('courier-last-update').innerText = '⏳ Yükleniyor...';
  try{
    const now = new Date();
    const todayStart = new Date(now); todayStart.setHours(0,0,0,0);
    const weekStart  = new Date(now); weekStart.setDate(now.getDate()-6); weekStart.setHours(0,0,0,0);

    const snap = await getDocs(rc("orders"));
    const all  = snap.docs.map(d=>({id:d.id,...d.data()}));

    // Bugünkü siparişler
    const todayOrders = all.filter(o=>{
      if(!o.date) return false;
      const d = o.date.toDate?o.date.toDate():new Date(o.date.seconds*1000);
      return d >= todayStart;
    });

    const activeDeliveries = todayOrders.filter(o=>o.status==='Yola Çıktı');
    const doneToday        = todayOrders.filter(o=>o.status==='Teslim Edildi');
    const cancelToday      = todayOrders.filter(o=>o.status==='İptal');

    // GECİKME HESAPLA (30 dk üzeri riskli, 45 dk üzeri gecikmeli)
    const LATE_THRESHOLD = 45; // dk
    const RISK_THRESHOLD = 30;

    function getElapsedMins(order){
      if(!order.date) return 0;
      const d = order.date.toDate?order.date.toDate():new Date(order.date.seconds*1000);
      return Math.floor((Date.now()-d.getTime())/60000);
    }

    const lateDeliveries = activeDeliveries.filter(o=>getElapsedMins(o)>=LATE_THRESHOLD);

    // Ortalama teslimat süresi (teslim edilenlerin onay→teslim süresi)
    // Sipariş tarihinden itibaren basit hesap
    const avgMins = doneToday.length > 0
      ? Math.round(doneToday.reduce((s,o)=>{
          // Eğer statusDates varsa kullan, yoksa siparişin üzerinden tahmini
          return s + (o.deliveryDuration || 35); // dk
        },0) / doneToday.length)
      : 0;

    const dailyCiro = doneToday.reduce((s,o)=>s+(parseFloat(o.total)||0),0);
    const cancelRate = todayOrders.length > 0
      ? (cancelToday.length/todayOrders.length*100).toFixed(0)
      : 0;

    // Üst stat kartlar
    document.getElementById('cs-active').innerText     = activeDeliveries.length;
    document.getElementById('cs-done-today').innerText = doneToday.length;
    document.getElementById('cs-late').innerText       = lateDeliveries.length;
    document.getElementById('cs-avg-time').innerText   = avgMins > 0 ? avgMins+'dk' : '—';
    document.getElementById('cs-daily-ciro').innerText = dailyCiro.toLocaleString('tr-TR')+'₺';
    document.getElementById('cs-cancel-rate').innerText= '%'+cancelRate;

    // ── AKTİF TESLİMATLAR ──────────────────────────────────────────────
    document.getElementById('active-delivery-badge').innerText = activeDeliveries.length;
    const deliveriesEl = document.getElementById('active-deliveries-list');
    if(!activeDeliveries.length){
      deliveriesEl.innerHTML=`<div style="text-align:center;padding:30px;color:#bbb;"><div style="font-size:36px;margin-bottom:8px;">🛵</div><div style="font-size:13px;">Şu an yolda sipariş yok</div></div>`;
    } else {
      deliveriesEl.innerHTML = activeDeliveries.map((o,i)=>{
        const elapsed = getElapsedMins(o);
        const addr = (o.addressDetails||o.address||'Adres yok').substring(0,40);
        let cls='', badgeCls='badge-ok', badgeTxt='🟢 Zamanında', dotColor='#27ae60';
        if(elapsed>=LATE_THRESHOLD){ cls='late'; badgeCls='badge-late'; badgeTxt='🔴 Gecikmeli'; dotColor='#c0392b'; }
        else if(elapsed>=RISK_THRESHOLD){ cls='late-risk'; badgeCls='badge-risk'; badgeTxt='🟡 Riskli'; dotColor='#f39c12'; }
        return `
          <div class="delivery-card ${cls}">
            <div class="delivery-num" style="background:${dotColor};">${i+1}</div>
            <div>
              <div class="delivery-name">${o.customer||'Müşteri'}</div>
              <div class="delivery-addr">📍 ${addr}</div>
              <div style="font-size:12px;color:#555;margin-top:3px;">📞 ${o.phone||'-'} · ${o.total} ₺</div>
            </div>
            <div class="delivery-time">
              <div class="delivery-elapsed">${elapsed}dk</div>
              <div class="delivery-status-badge ${badgeCls}">${badgeTxt}</div>
            </div>
          </div>`;
      }).join('');
    }

    // ── HARİTA ─────────────────────────────────────────────────────────
    const mapOverlay = document.getElementById('map-overlay');
    const mapEl      = document.getElementById('courier-map');
    if(activeDeliveries.length > 0){
      const firstAddr = activeDeliveries[0].addressDetails || activeDeliveries[0].address || '';
      if(firstAddr){
        mapOverlay.style.display='none';
        const iframeUrl = `https://maps.google.com/maps?q=${encodeURIComponent(firstAddr)}&output=embed&z=14`;
        mapEl.innerHTML = `
          <iframe src="${iframeUrl}" allowfullscreen loading="lazy"></iframe>
          <div style="position:absolute;top:10px;right:10px;display:flex;flex-direction:column;gap:6px;z-index:5;">
            ${activeDeliveries.map((o,i)=>{
              const elapsed=getElapsedMins(o);
              const color=elapsed>=LATE_THRESHOLD?'#c0392b':elapsed>=RISK_THRESHOLD?'#f39c12':'#27ae60';
              return `<div style="background:white;padding:6px 10px;border-radius:8px;font-size:12px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.2);border-left:4px solid ${color};">
                🛵 ${o.customer||'#'+(i+1)} · ${elapsed}dk
              </div>`;
            }).join('')}
          </div>`;
      } else {
        mapOverlay.style.display='flex';
        mapEl.querySelector('iframe') && mapEl.querySelector('iframe').remove();
      }
    } else {
      mapOverlay.style.display='flex';
      const iframe = mapEl.querySelector('iframe');
      if(iframe) iframe.remove();
    }

    // ── GECİKME ZAMANÇİZELGESİ ─────────────────────────────────────────
    const tlEl = document.getElementById('delay-timeline');
    const recentOrders = [...todayOrders]
      .filter(o=>o.status==='Teslim Edildi'||o.status==='İptal'||o.status==='Yola Çıktı')
      .sort((a,b)=>(b.date?.seconds||0)-(a.date?.seconds||0))
      .slice(0,8);

    if(!recentOrders.length){
      tlEl.innerHTML='<div style="text-align:center;padding:20px;color:#bbb;font-size:13px;">Bugün henüz sipariş yok.</div>';
    } else {
      tlEl.innerHTML = recentOrders.map(o=>{
        const d = o.date?.toDate?o.date.toDate():new Date(o.date?.seconds*1000||0);
        const timeStr = d.toLocaleTimeString('tr-TR',{hour:'2-digit',minute:'2-digit'});
        const elapsed = Math.floor((Date.now()-d.getTime())/60000);
        let dotColor='#27ae60', badgeColor='#e8f8f5', badgeTxt='Teslim', textColor='#27ae60';
        if(o.status==='İptal'){ dotColor='#c0392b'; badgeColor='#fdedec'; badgeTxt='İptal'; textColor='#c0392b'; }
        else if(o.status==='Yola Çıktı'){
          if(elapsed>=LATE_THRESHOLD){ dotColor='#c0392b'; badgeColor='#fdedec'; badgeTxt='Gecikmeli'; textColor='#c0392b'; }
          else if(elapsed>=RISK_THRESHOLD){ dotColor='#f39c12'; badgeColor='#fef9e7'; badgeTxt='Riskli'; textColor='#f39c12'; }
          else { dotColor='#e67e22'; badgeColor='#fff3e0'; badgeTxt='Yolda'; textColor='#e67e22'; }
        }
        return `<div class="timeline-row">
          <div class="tl-dot" style="background:${dotColor};box-shadow:0 0 6px ${dotColor}40;"></div>
          <div><div class="tl-name">${o.customer||'Müşteri'}</div><div class="tl-addr">${(o.addressDetails||o.address||'').substring(0,35)}</div></div>
          <div style="text-align:right;">
            <div class="tl-time">${timeStr}</div>
            <span class="tl-badge" style="background:${badgeColor};color:${textColor};">${badgeTxt}</span>
          </div>
        </div>`;
      }).join('');
    }

    // ── PERFORMANS ──────────────────────────────────────────────────────
    const perfEl = document.getElementById('courier-perf-area');
    const stats = [
      {label:'Teslim Edilen', val:doneToday.length, max:Math.max(doneToday.length,1), color:'#27ae60', icon:'✅'},
      {label:'Toplam Sipariş', val:todayOrders.length, max:Math.max(todayOrders.length,1), color:'#3498db', icon:'📦'},
      {label:'İptal Edilen', val:cancelToday.length, max:Math.max(todayOrders.length,1), color:'#c0392b', icon:'❌'},
      {label:'Aktif Yolda', val:activeDeliveries.length, max:Math.max(activeDeliveries.length,1), color:'#e67e22', icon:'🛵'},
    ];
    perfEl.innerHTML = `<div style="margin-bottom:16px;">` +
      stats.map(s=>`
        <div style="margin-bottom:14px;">
          <div style="display:flex;justify-content:space-between;margin-bottom:5px;font-size:13px;">
            <span>${s.icon} ${s.label}</span>
            <span style="font-weight:800;color:${s.color};">${s.val}</span>
          </div>
          <div class="perf-bar-bg"><div class="perf-bar-fill" style="width:${(s.val/s.max*100).toFixed(0)}%;background:${s.color};"></div></div>
        </div>`).join('')
      + `</div>`
      + `<div style="background:#f8f9fa;border-radius:8px;padding:14px;">
          <div style="font-size:12px;color:#95a5a6;margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Günlük Özet</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:13px;">
            <div>💰 Ciro: <b style="color:var(--primary);">${dailyCiro.toLocaleString('tr-TR')} ₺</b></div>
            <div>⚡ Ort: <b>${avgMins>0?avgMins+'dk':'—'}</b></div>
            <div>❌ İptal: <b style="color:#c0392b;">%${cancelRate}</b></div>
            <div>🔴 Gecikmeli: <b style="color:#c0392b;">${lateDeliveries.length}</b></div>
          </div>
        </div>`;

    // ── SAATLİK YOĞUNLUK ────────────────────────────────────────────────
    const hourMap = Array(24).fill(0);
    todayOrders.forEach(o=>{ if(!o.date) return; const d=o.date.toDate?o.date.toDate():new Date(o.date.seconds*1000); hourMap[d.getHours()]++; });
    const maxHour = Math.max(...hourMap,1);
    const chartEl = document.getElementById('courier-hour-chart');
    chartEl.innerHTML='';
    // Sadece 8-24 arası göster
    for(let h=8;h<24;h++){
      const cnt=hourMap[h]; const pct=Math.max((cnt/maxHour*100),2);
      const col=document.createElement('div'); col.className='hbar-col';
      col.innerHTML=`<div class="hbar" style="height:${pct}%;background:${cnt>0?'var(--primary)':'#ecf0f1'};">
        <div class="hbar-tt">${h}:00 · ${cnt} sipariş</div></div>
        <div class="hbar-lbl">${h}</div>`;
      chartEl.appendChild(col);
    }
    const peakHour = hourMap.indexOf(Math.max(...hourMap));
    const peakEl   = document.getElementById('courier-hour-peak');
    if(Math.max(...hourMap)>0){
      peakEl.innerHTML=`<span style="background:#fff3e0;padding:6px 12px;border-radius:8px;border-left:3px solid var(--primary);font-size:13px;display:inline-block;">🔥 En yoğun saat: <b>${peakHour}:00–${peakHour+1}:00</b> (${hourMap[peakHour]} sipariş)</span>`;
    } else { peakEl.innerHTML=''; }

    // ── BÖLGE ANALİZİ ───────────────────────────────────────────────────
    // Adresten bölge çıkarımı (ilk kelime/mahalle)
    const zoneMap={};
    todayOrders.filter(o=>o.status==='Teslim Edildi').forEach(o=>{
      const addr = o.addressDetails||o.address||'';
      // Adresin ilk anlamlı kelimesini bölge olarak kullan
      const parts = addr.split(/[,\/\n]/);
      let zone = (parts[0]||'').trim().substring(0,20)||'Bilinmeyen';
      if(!zoneMap[zone]) zoneMap[zone]={count:0,total:0};
      zoneMap[zone].count++;
      zoneMap[zone].total += parseFloat(o.total)||0;
    });
    const zones = Object.entries(zoneMap).sort((a,b)=>b[1].count-a[1].count).slice(0,8);
    const zoneEl = document.getElementById('zone-grid');
    if(!zones.length){
      zoneEl.innerHTML='<div style="text-align:center;padding:20px;color:#bbb;font-size:13px;grid-column:1/-1;">Bugün teslim edilmiş sipariş yok. Bölge analizi için veriye ihtiyaç var.</div>';
    } else {
      const zoneColors=['#d35400','#e67e22','#f39c12','#27ae60','#3498db','#9b59b6','#e74c3c','#1abc9c'];
      zoneEl.innerHTML = zones.map(([name,data],i)=>`
        <div class="zone-card" style="border-top-color:${zoneColors[i%zoneColors.length]};">
          <div class="zone-name">${name}</div>
          <div class="zone-count" style="color:${zoneColors[i%zoneColors.length]};">${data.count}</div>
          <div class="zone-avg">📦 Teslimat</div>
          <div style="font-size:12px;color:#95a5a6;margin-top:2px;">${(data.total/data.count).toFixed(0)} ₺ ort.</div>
        </div>`).join('');
    }

    // ── HAFTALIK RAPOR ──────────────────────────────────────────────────
    const weekOrders = all.filter(o=>{
      if(!o.date||o.status!=='Teslim Edildi') return false;
      const d=o.date.toDate?o.date.toDate():new Date(o.date.seconds*1000);
      return d>=weekStart;
    });
    document.getElementById('weekly-total').innerText = weekOrders.length;
    document.getElementById('weekly-avg-time').innerText = '~35dk';
    document.getElementById('weekly-ciro').innerText = weekOrders.reduce((s,o)=>s+(parseFloat(o.total)||0),0).toLocaleString('tr-TR')+'₺';

    // Haftalık gecikmeli tahmin (basit)
    const weekLate = all.filter(o=>{
      if(!o.date||o.status!=='Teslim Edildi') return false;
      const d=o.date.toDate?o.date.toDate():new Date(o.date.seconds*1000);
      if(d<weekStart) return false;
      return (o.deliveryDuration||35)>LATE_THRESHOLD;
    });
    document.getElementById('weekly-late').innerText = weekLate.length;

    // Günlük ciro grafiği (son 7 gün)
    const dailyMap7={};
    weekOrders.forEach(o=>{
      const d=o.date.toDate?o.date.toDate():new Date(o.date.seconds*1000);
      const key=d.toLocaleDateString('tr-TR',{day:'2-digit',month:'2-digit'});
      dailyMap7[key]=(dailyMap7[key]||0)+(parseFloat(o.total)||0);
    });
    const last7=[]; const cur=new Date(weekStart);
    while(cur<=now){
      const key=cur.toLocaleDateString('tr-TR',{day:'2-digit',month:'2-digit'});
      last7.push({key,val:dailyMap7[key]||0});
      cur.setDate(cur.getDate()+1);
    }
    const maxW=Math.max(...last7.map(d=>d.val),1);
    const wChartEl=document.getElementById('weekly-chart'), wLabelsEl=document.getElementById('weekly-chart-labels');
    wChartEl.innerHTML=''; wLabelsEl.innerHTML='';
    last7.forEach(d=>{
      const col=document.createElement('div'); col.className='chart-bar-col';
      col.innerHTML=`<div class="chart-bar" style="height:${Math.max((d.val/maxW*100),2)}%;">
        <div class="chart-bar-tooltip">${d.key}<br>${d.val.toLocaleString('tr-TR')} ₺</div></div>`;
      wChartEl.appendChild(col);
    });
    const lb1=document.createElement('span'); lb1.innerText=last7[0]?.key||'';
    const lb2=document.createElement('span'); lb2.innerText=last7[last7.length-1]?.key||'';
    wLabelsEl.appendChild(lb1); wLabelsEl.appendChild(lb2);

    document.getElementById('courier-last-update').innerText = `Son güncelleme: ${new Date().toLocaleTimeString('tr-TR')}`;
  }catch(e){
    toast("Kurye paneli yüklenemedi: "+e.message, true);
    console.error(e);
    document.getElementById('courier-last-update').innerText = '❌ Hata';
  }
}

