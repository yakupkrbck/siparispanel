window.searchPersonalCustomers = async () => {
  const q = document.getElementById('personal-search').value.trim();
  const box = document.getElementById('personal-search-results');
  if(q.length < 2) { box.style.display='none'; return; }
  box.style.display='block';
  box.innerHTML = '<div style="padding:8px 12px;color:#aaa;font-size:12px;">Aranıyor...</div>';
  try {
    const snap = await getDocs(rc("customers"));
    const results = snap.docs.map(d=>({id:d.id,...d.data()}))
      .filter(c => (c.name||'').toLowerCase().includes(q.toLowerCase()) || (c.phone||'').includes(q))
      .slice(0,8);
    if(!results.length){ box.innerHTML='<div style="padding:8px 12px;color:#aaa;font-size:12px;">Bulunamadı</div>'; return; }
