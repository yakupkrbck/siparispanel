    ${locBtn}
    <div class="oitems">${items}</div>${note}
    <div class="bgrp">${btns}</div>`;
  const col_el=document.getElementById(col);
  if(col_el) col_el.appendChild(card);
}
window.updStatus=async(id,s)=>{
  stopAlarm();
  try{
    await updateDoc(rds("orders",id),{status:s});
    if(s==='Teslim Edildi'){
      try{
        const orderDoc=await getDoc(rds("orders",id));
        if(orderDoc.exists()){
          const order=orderDoc.data(); const phone=order.phone;
          await updateDoc(rds("orders",id),{ deliveredAt: serverTimestamp() });
          if(phone){
            const q=query(rc("customers"),where("phone","==",phone));
            const snap=await getDocs(q);
            if(!snap.empty){
              // VIP ayarlarını oku (Firestore'da yoksa default)
              let vs={bronz:{min:2,rate:4},gumus:{min:4,rate:7},altin:{min:8,rate:10}};
              try{ const vsnap=await getDoc(rdc("settings","vip")); if(vsnap.exists()) vs=vsnap.data(); }catch(_){}
              // Son 30 günün teslim edilen sipariş sayısı (bu sipariş dahil)
              const thirtyAgo=new Date(Date.now()-30*24*60*60*1000);
              const recentSnap=await getDocs(query(rc("orders"),where('phone','==',phone),where('status','==','Teslim Edildi')));
              const recentCount=recentSnap.docs.filter(d=>{const dt=d.data().date; const t=dt?.toDate?dt.toDate():new Date((dt?.seconds||0)*1000); return t>=thirtyAgo;}).length + 1; // +1 bu sipariş
              // Seviye & oran
              let rate=0,levelLabel='Normal 👤',levelKey='normal';
              if(recentCount>=(vs.altin?.min??8)){rate=(vs.altin?.rate??10)/100;levelLabel='Altın 🥇';levelKey='altin';}
              else if(recentCount>=(vs.gumus?.min??4)){rate=(vs.gumus?.rate??7)/100;levelLabel='Gümüş 🥈';levelKey='gumus';}
              else if(recentCount>=(vs.bronz?.min??2)){rate=(vs.bronz?.rate??4)/100;levelLabel='Bronz 🥉';levelKey='bronz';}
              const earnedPoints=Math.floor(order.total*rate);
              const custData=snap.docs[0].data();
              const history=custData.pointsHistory||[];
              const currentPts=custData.loyaltyPoints||0;
              const updateData={orderCount:increment(1),lastOrderDate:new Date()};
              if(earnedPoints>0){
                history.unshift({earned:earnedPoints,total:currentPts+earnedPoints,date:new Date().toLocaleDateString('tr-TR'),orderTotal:order.total,level:levelLabel});
                if(history.length>20) history.pop();
                updateData.loyaltyPoints=increment(earnedPoints);
                updateData.pointsHistory=history;
                toast(`✅ Teslim edildi. ${levelLabel} — ${earnedPoints} puan kazandı! (%${vs[levelKey]?.rate??0} × ${order.total}₺)`);
              } else {
                toast(`✅ Teslim edildi. ${levelLabel} — puan kazanılmadı.`);
              }
              await updateDoc(snap.docs[0].ref,updateData);
            } else { toast('⚠️ Teslim edildi ama müşteri kaydı bulunamadı'); }
          }
        }
      }catch(e){ toast(`⚠️ Teslim edildi ama puan verilemedi: `+e.message,true); }
      sendPushToCustomer(id, '🎉 Siparişiniz Teslim Edildi!', 'Afiyet olsun! Tekrar bekleriz 😊');
    } else if(s==='Yola Çıktı') {
      toast("Güncellendi.");
      sendPushToCustomer(id, '🛵 Siparişiniz Yola Çıktı!', 'Kurye kapınıza doğru yola çıktı. Az kaldı!');
    } else if(s==='İptal') {
      // Kupon kullanıldıysa usedCount'u geri al
      try {
        const cancelDoc = await getDoc(rds("orders",id));
        if(cancelDoc.exists()) {
          const cancelOrder = cancelDoc.data();
          if(cancelOrder.discountCode) {
            const cq = query(rc("coupons"), where("code","==",cancelOrder.discountCode));
            const csnap = await getDocs(cq);
            if(!csnap.empty) {
              const currentUsed = csnap.docs[0].data().usedCount || 0;
              if(currentUsed > 0) {
                await updateDoc(csnap.docs[0].ref, { usedCount: increment(-1) });
                toast('⚠️ İptal edildi. "' + cancelOrder.discountCode + '" kuponu iade edildi.');
              } else {
                toast('⚠️ Sipariş iptal edildi.');
              }
            } else {
              toast('⚠️ Sipariş iptal edildi.');
            }
          } else {
            toast('⚠️ Sipariş iptal edildi.');
          }
        }
      } catch(ce) {
