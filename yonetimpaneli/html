};
// ── SERVICE WORKER KAYDI ──
let _swRegistration = null;
if('serviceWorker' in navigator) {
    // Kayıt yap ve ready ile garantile
    navigator.serviceWorker.register('/sw.js')
        .then(reg => { _swRegistration = reg; console.log('SW kayıtlı'); })
        .catch(e => console.log('SW hatası:', e));

    // Sayfa yenilenince mevcut SW'yi de al
    navigator.serviceWorker.ready.then(reg => { _swRegistration = reg; });
    
    // SW'den gelen mesajları dinle (Onayla/Reddet)
    navigator.serviceWorker.addEventListener('message', async event => {
        const { type, orderId } = event.data || {};
        if(type === 'APPROVE_ORDER' && orderId) {
            await approve(orderId);
        } else if(type === 'REJECT_ORDER' && orderId) {
            await updStatus(orderId, 'İptal');
        }
    });
}

function sendNotif(o){ 
    const s = getNotifSettings();
    if(s.popupEnabled === false) return;

    const itemsList = (o.items||[]).map(i=>i.n).join(', ');
    const title = "🔔 YENİ SİPARİŞ!";
    const body = `👤 ${o.customer} — ${o.total} TL
🛒 ${itemsList}
📍 ${(o.addressDetails||'').substring(0,35)}`;

    // Electron varsa → alarm penceresi aç (SambaPOS üstüne çıkar)
    if(window.electronAPI) {
        window.electronAPI.showAlarmWindow(o);
        return;
    }

    // Tarayıcı bildirimi
    if(!("Notification" in window)) return;
    if(Notification.permission !== "granted") {
        if(Notification.permission !== "denied") reqNotif();
        return;
    }

    const notifOptions = {
        body,
        requireInteraction: true,
        tag: 'new-order-' + o.id,
        icon: '/icons/icon-192.png'
    };

    try {
        // Direkt Notification - SW gerektirmez
        new Notification(title, notifOptions);
    } catch(e){ console.error('Bildirim hatası:', e); }
}
