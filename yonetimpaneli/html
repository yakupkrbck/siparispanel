window.loadVipStats=async()=>{
  const el=document.getElementById('vip-stats');
  if(!el) return;
  el.innerHTML='<div style="color:#aaa;font-size:13px;">Yükleniyor...</div>';
  try{
    let vs={bronz:{min:2},gumus:{min:4},altin:{min:8}};
    try{ const vs2=await getDoc(rdc("settings","vip")); if(vs2.exists()) vs=vs2.data(); }catch(_){}
    const thirtyAgo=new Date(Date.now()-30*24*60*60*1000);
    const custSnap=await getDocs(rc("customers"));
    const counts={altin:0,gumus:0,bronz:0,normal:0};
    // Her müşteri için son 30 günlük sipariş sayısı — toplu sorgu
    await Promise.all(custSnap.docs.map(async cd=>{
      const phone=cd.data().phone||cd.id;
      try{
        const rSnap=await getDocs(query(rc("orders"),where('phone','==',phone),where('status','==','Teslim Edildi')));
        const cnt=rSnap.docs.filter(d=>{const dt=d.data().date;const t=dt?.toDate?dt.toDate():new Date((dt?.seconds||0)*1000);return t>=thirtyAgo;}).length;
        if(cnt>=(vs.altin?.min??8)) counts.altin++;
        else if(cnt>=(vs.gumus?.min??4)) counts.gumus++;
        else if(cnt>=(vs.bronz?.min??2)) counts.bronz++;
        else counts.normal++;
      }catch(_){ counts.normal++; }
    }));
    const total=counts.altin+counts.gumus+counts.bronz+counts.normal;
    el.innerHTML=`
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <div style="flex:1;min-width:80px;background:#fffde7;border-radius:10px;padding:14px;text-align:center;border:1.5px solid #f9ca24;">
          <div style="font-size:26px;">🥇</div><div style="font-size:22px;font-weight:900;color:#b7950b;">${counts.altin}</div><div style="font-size:11px;color:#aaa;">Altın</div>
        </div>
        <div style="flex:1;min-width:80px;background:#f8f8f8;border-radius:10px;padding:14px;text-align:center;border:1.5px solid #bdc3c7;">
          <div style="font-size:26px;">🥈</div><div style="font-size:22px;font-weight:900;color:#7f8c8d;">${counts.gumus}</div><div style="font-size:11px;color:#aaa;">Gümüş</div>
        </div>
        <div style="flex:1;min-width:80px;background:#fff8f2;border-radius:10px;padding:14px;text-align:center;border:1.5px solid #f5cba7;">
          <div style="font-size:26px;">🥉</div><div style="font-size:22px;font-weight:900;color:#cd7f32;">${counts.bronz}</div><div style="font-size:11px;color:#aaa;">Bronz</div>
        </div>
        <div style="flex:1;min-width:80px;background:#fafafa;border-radius:10px;padding:14px;text-align:center;border:1.5px dashed #eee;">
          <div style="font-size:26px;">👤</div><div style="font-size:22px;font-weight:900;color:#ccc;">${counts.normal}</div><div style="font-size:11px;color:#aaa;">Normal</div>
        </div>
      </div>
      <div style="font-size:12px;color:#aaa;">Toplam ${total} aktif müşteri · Son 30 günlük teslimlara göre</div>`;
  }catch(e){ el.innerHTML=`<div style="color:red;font-size:13px;">Yüklenemedi: ${e.message}</div>`; }
};
