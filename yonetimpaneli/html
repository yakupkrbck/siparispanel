window.updateClosedDayStyle = (day) => {
  const checked = document.getElementById(`cd-${day}`).checked;
  const lbl = document.getElementById(`cd-label-${day}`);
  lbl.style.borderColor = checked ? '#e74c3c' : '#ddd';
  lbl.style.background  = checked ? '#fdedec' : 'white';
  lbl.style.color       = checked ? '#c0392b' : '#444';
};

window.loadStoreHours=async()=>{
  try{
    const snap=await getDoc(rdc("settings","general"));
    const data = snap.exists() ? snap.data() : {};
    document.getElementById('open-time').value  = data.openTime  || '10:30';
    document.getElementById('close-time').value = data.closeTime || '22:00';
    // Kapalı günler
    const closed = data.closedDays || [];
    [0,1,2,3,4,5,6].forEach(d => {
      const el = document.getElementById(`cd-${d}`);
      if(el){ el.checked = closed.includes(d); updateClosedDayStyle(d); }
    });
    updateCurrentHoursDisplay(data.openTime||'10:30', data.closeTime||'22:00', closed);
  }catch(e){ document.getElementById('current-hours').innerHTML='<span style="color:#c0392b;">Yüklenemedi.</span>'; }
};
window.saveStoreHours=async()=>{
  const openTime=document.getElementById('open-time').value, closeTime=document.getElementById('close-time').value;
  if(!openTime||!closeTime){ showHoursStatus('⚠️ Lütfen her iki saati de girin.','warn'); return; }
  const [oh,om]=openTime.split(':').map(Number), [ch,cm]=closeTime.split(':').map(Number);
  if(ch*60+cm<=oh*60+om){ showHoursStatus('⚠️ Kapanış saati açılış saatinden sonra olmalı.','warn'); return; }
  const closedDays = [0,1,2,3,4,5,6].filter(d => document.getElementById(`cd-${d}`)?.checked);
  try{
    await setDoc(rdc("settings","general"),{openTime,closeTime,closedDays},{merge:true});
    updateCurrentHoursDisplay(openTime,closeTime,closedDays);
    showHoursStatus('✅ Çalışma saatleri kaydedildi!','success');
    toast('✅ Çalışma saatleri güncellendi');
  }catch(e){ showHoursStatus('❌ Kaydetme hatası: '+e.message,'error'); }
};

// ── TESLİMAT BÖLGELERİ ──────────────────────────────────────────────────────
let _deliveryZones = []; // [{label, keys:[], min}]

window.loadDeliveryZones = async () => {
  try {
    const snap = await getDoc(rdc("settings","deliveryZones"));
    if(snap.exists()) {
      const data = snap.data();
      _deliveryZones = data.zones || [];
      document.getElementById('zone-default-min').value = data.defaultMin ?? 300;
    } else {
      // Hardcoded varsayılanları yükle
      _deliveryZones = [
        {label:'Mehmet Akif', keys:['mehmet akif'], min:60},
        {label:'Çeltik',      keys:['celtik'],      min:300},
        {label:'Çukurca',     keys:['cukurca'],     min:300},
      ];
    }
    renderZoneList();
  } catch(e) { console.warn('Bölgeler yüklenemedi:', e); }
};

function renderZoneList() {
  const container = document.getElementById('zone-list');
  if(!container) return;
  if(_deliveryZones.length === 0) {
    container.innerHTML = '<div style="text-align:center;color:#bbb;font-size:13px;padding:12px;">Henüz özel bölge tanımlanmamış.</div>';
    return;
  }
  container.innerHTML = _deliveryZones.map((z,i) => `
    <div style="display:flex;align-items:center;gap:10px;background:#fafafa;border-radius:10px;padding:11px 14px;border:1.5px solid #eee;" id="zone-row-${i}">
      <span style="font-size:16px;">📍</span>
      <div style="flex:1;min-width:0;">
        <div style="font-weight:700;font-size:13px;color:var(--dark);">${z.label}</div>
        <div style="font-size:11px;color:#aaa;margin-top:1px;">🔑 ${z.keys.join(', ')}</div>
      </div>
      <input type="number" value="${z.min}" min="0" step="10"
        style="width:72px;text-align:center;padding:6px;border:1.5px solid #ddd;border-radius:8px;font-weight:700;font-size:13px;"
        onchange="updateZoneMin(${i}, this.value)">
      <span style="font-size:12px;color:#888;flex-shrink:0;">₺</span>
      <button onclick="removeZone(${i})" style="background:none;border:none;color:#e74c3c;font-size:16px;cursor:pointer;padding:4px;line-height:1;" title="Sil">✕</button>
    </div>`).join('');
}

window.updateZoneMin = (i, val) => { _deliveryZones[i].min = parseInt(val)||0; };
window.removeZone = (i) => { _deliveryZones.splice(i,1); renderZoneList(); };
window.addDeliveryZone = () => {
  const label = document.getElementById('zone-new-label').value.trim();
  const keysRaw = document.getElementById('zone-new-keys').value.trim();
  const min = parseInt(document.getElementById('zone-new-min').value)||0;
  if(!label){ toast('❌ Mahalle adı girin',true); return; }
  const keys = keysRaw ? keysRaw.split(',').map(k=>k.trim().toLowerCase()).filter(Boolean) : [label.toLowerCase()];
  _deliveryZones.push({label, keys, min});
  document.getElementById('zone-new-label').value='';
  document.getElementById('zone-new-keys').value='';
  document.getElementById('zone-new-min').value='';
  renderZoneList();
};
window.saveDeliveryZones = async () => {
  const defaultMin = parseInt(document.getElementById('zone-default-min').value)||300;
  const data = { zones: _deliveryZones, defaultMin, updatedAt: new Date().toISOString() };
  try {
    await setDoc(rdc("settings","deliveryZones"), data);
    const el = document.getElementById('zone-save-status');
    el.style.display='block'; el.style.background='#e8f8f5'; el.style.color='#27ae60'; el.style.border='1px solid #d4efdf';
    el.innerHTML='✅ Bölgeler kaydedildi! Sipariş uygulaması otomatik güncellenir.';
    setTimeout(()=>el.style.display='none',4000);
    toast('✅ Teslimat bölgeleri güncellendi');
  } catch(e) {
    const el = document.getElementById('zone-save-status');
    el.style.display='block'; el.style.background='#fdedec'; el.style.color='#c0392b'; el.style.border='1px solid #fadbd8';
    el.innerHTML='❌ Kaydedilemedi: '+e.message;
    toast('❌ Kayıt hatası: '+e.message, true);
  }
};
function updateCurrentHoursDisplay(open,close,closedDays=[]){
  const dayNames=['Paz','Pzt','Sal','Çar','Per','Cum','Cmt'];
  const closedTxt = closedDays.length
    ? `<div style="display:flex;justify-content:space-between;margin-top:6px;"><span><strong>Kapalı Günler:</strong></span><span style="font-weight:700;color:#c0392b;">${closedDays.map(d=>dayNames[d]).join(', ')}</span></div>`
    : `<div style="display:flex;justify-content:space-between;margin-top:6px;"><span><strong>Kapalı Günler:</strong></span><span style="color:#27ae60;font-weight:600;">Yok (Her gün açık)</span></div>`;
  document.getElementById('current-hours').innerHTML=`<div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span><strong>Açılış:</strong></span><span style="font-weight:700;color:var(--success);">${open}</span></div><div style="display:flex;justify-content:space-between;"><span><strong>Kapanış:</strong></span><span style="font-weight:700;color:var(--danger);">${close}</span></div>${closedTxt}`;
}
function showHoursStatus(msg,type){
  const el=document.getElementById('hours-status'); const colors={success:{bg:'#e8f8f5',text:'#27ae60',border:'#d4efdf'},warn:{bg:'#fef9e7',text:'#f39c12',border:'#fcf3cf'},error:{bg:'#fdedec',text:'#c0392b',border:'#fadbd8'}};
  const c=colors[type]||colors.warn; el.style.background=c.bg; el.style.color=c.text; el.style.border=`1px solid ${c.border}`; el.innerHTML=msg; el.style.display='block'; setTimeout(()=>el.style.display='none',4000);
}

// ── RAPORLAMA ────────────────────────────────────────────────────────────────
function initReportDates(){ const now=new Date(); const start=new Date(now.getFullYear(),now.getMonth(),1); const fmt=d=>d.toISOString().split('T')[0]; document.getElementById('rpt-date-start').value=fmt(start); document.getElementById('rpt-date-end').value=fmt(now); }
window.setQuickRange=(key,btn)=>{
  const now=new Date(); const fmt=d=>d.toISOString().split('T')[0]; let start, end=new Date(now);
  if(key==='today'){ start=new Date(now); start.setHours(0,0,0,0); }
  else if(key==='yesterday'){ start=new Date(now); start.setDate(start.getDate()-1); start.setHours(0,0,0,0); end=new Date(start); end.setHours(23,59,59,999); }
  else if(key==='week'){ start=new Date(now); const day=now.getDay(); start.setDate(now.getDate()-(day===0?6:day-1)); start.setHours(0,0,0,0); }
  else if(key==='month'){ start=new Date(now.getFullYear(),now.getMonth(),1); }
  else if(key==='last30'){ start=new Date(now); start.setDate(start.getDate()-29); }
