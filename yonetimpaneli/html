window.fetchProducts=async()=>{
  const tbody=document.getElementById('prod-body');
  tbody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:20px;">Yükleniyor...</td></tr>';
  try{
    const snap=await getDocs(rc("products"));
    if(snap.empty){ tbody.innerHTML='<tr><td colspan="6" style="text-align:center;">Ürün yok.</td></tr>'; return; }
    const normalizeCategory=cat=>{ if(!cat) return "Diğer"; const decoded=cat.replace(/&amp;/g,'&').replace(/&#38;/g,'&').trim(); const match=CATEGORIES.find(c=>c.toLowerCase()===decoded.toLowerCase()); return match||decoded; };
    const byCat={};
    snap.docs.forEach(d=>{ const p={id:d.id,...d.data()}; const cat=normalizeCategory(p.category||p.cat||"Diğer"); if(!byCat[cat]) byCat[cat]=[]; byCat[cat].push(p); });
    tbody.innerHTML='';
    const sorted=[...CATEGORIES.filter(c=>byCat[c]),...Object.keys(byCat).filter(c=>!CATEGORIES.includes(c))];
    sorted.forEach(cat=>{
      const products=byCat[cat].sort((a,b)=>(a.order||0)-(b.order||0));
      const hRow=document.createElement('tr'); hRow.className='cat-header'; hRow.innerHTML=`<td colspan="6">${cat} (${products.length})</td>`; tbody.appendChild(hRow);
      products.forEach(p=>{
        const row=document.createElement('tr'); row.className='drag-row'; row.draggable=true; row.dataset.id=p.id; row.dataset.cat=cat;
        row.innerHTML=`<td style="color:#bbb;font-size:18px;cursor:grab;text-align:center;">⠿</td>
          <td><div style="display:flex;align-items:center;gap:8px;">${(p.image||p.i)?`<img src="${p.image||p.i}" style="width:36px;height:36px;border-radius:6px;object-fit:cover;">`:`<div style="width:36px;height:36px;border-radius:6px;background:#eee;display:flex;align-items:center;justify-content:center;font-size:18px;">🍽</div>`}<div><div style="font-weight:600;">${p.name||p.n||'-'}</div>${p.options?.length?`<div style="font-size:11px;color:#888;">${p.options.length} seçenek</div>`:''}</div></div></td>
          <td><span style="background:#ecf0f1;padding:3px 8px;border-radius:10px;font-size:12px;">${cat}</span></td>
          <td style="font-weight:700;color:var(--primary);">${p.price||p.p||0} TL</td>
          <td><label class="switch"><input type="checkbox" ${p.inStock!==false?'checked':''} onchange="toggleStock('${p.id}',this.checked)"><span class="slider"></span></label></td>
          <td><div style="display:flex;gap:5px;"><button onclick="openEditProd('${p.id}')" class="btn" style="background:#3498db;width:auto;padding:6px 10px;font-size:12px;"><i class="fas fa-edit"></i></button><button onclick="deleteProd('${p.id}','${(p.name||p.n||'').replace(/'/g,"\\'")}' )" class="btn" style="background:#c0392b;width:auto;padding:6px 10px;font-size:12px;"><i class="fas fa-trash"></i></button></div></td>`;
        row.addEventListener('dragstart',e=>{ dragSrcId=p.id; dragSrcCat=cat; e.dataTransfer.effectAllowed='move'; setTimeout(()=>row.classList.add('dragging'),0); });
        row.addEventListener('dragend',()=>{ row.classList.remove('dragging'); tbody.querySelectorAll('.drag-over').forEach(r=>r.classList.remove('drag-over')); });
        row.addEventListener('dragover',e=>{ e.preventDefault(); tbody.querySelectorAll('.drag-over').forEach(r=>r.classList.remove('drag-over')); if(row.dataset.id!==dragSrcId) row.classList.add('drag-over'); });
        row.addEventListener('dragleave',()=>row.classList.remove('drag-over'));
        row.addEventListener('drop',async e=>{ e.preventDefault(); row.classList.remove('drag-over'); if(!dragSrcId||dragSrcId===p.id) return; await reorderProducts(dragSrcId,dragSrcCat,p.id,cat,tbody); });
        tbody.appendChild(row);
      });
    });
  }catch(e){ toast("❌ Hata: "+e.message,true); }
};
async function reorderProducts(fromId,fromCat,toId,toCat,tbody){
  if(fromCat!==toCat){ toast("⚠️ Farklı kategoriler arası taşıma desteklenmiyor.",true); return; }
  const rows=[...tbody.querySelectorAll(`tr.drag-row[data-cat="${CSS.escape(fromCat)}"]`)];
  const ids=rows.map(r=>r.dataset.id);
  const fromIdx=ids.indexOf(fromId), toIdx=ids.indexOf(toId);
  if(fromIdx<0||toIdx<0) return;
  ids.splice(fromIdx,1); ids.splice(toIdx,0,fromId);
  const batch=(await import("https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js")).writeBatch(db);
  ids.forEach((id,idx)=>{ batch.update(rds("products",id),{order:idx}); });
  try{ await batch.commit(); toast("Sıralama kaydedildi ✅"); fetchProducts(); }catch(e){ toast("Sıralama hatası: "+e.message,true); }
}
window.addProduct=async()=>{
  const name=document.getElementById('np-name').value.trim(), price=document.getElementById('np-price').value, cat=document.getElementById('np-cat').value, img=document.getElementById('np-img').value.trim();
  if(!name||!price){ toast("❌ Ürün adı ve fiyat zorunlu",true); return; }
  const snap=await getDocs(rc("products")); const order=snap.size;
  await addDoc(rc("products"),{name,price:Number(price),category:cat,image:img||null,inStock:true,options:[],order});
  toast("Ürün eklendi ✅"); document.getElementById('np-name').value=''; document.getElementById('np-price').value=''; document.getElementById('np-img').value=''; fetchProducts();
};
window.toggleStock=async(id,val)=>{
  try{
    const today = new Date().toISOString().split('T')[0]; // YYYY-MM-DD
    const upd = val ? {inStock:true, stockOffDate:null} : {inStock:false, stockOffDate:today};
    await updateDoc(rds("products",id),upd);
    toast(val?"✅ Stokta":"🚫 Stok Kapalı (Yarın otomatik açılır)");
  }catch(e){ toast("Hata",true); }
};
window.deleteProd=async(id,name)=>{ const confirmed=await showConfirmDialog(`"${name}" ürününü silmek istediğinize emin misiniz?`); if(!confirmed) return; try{ await deleteDoc(rds("products",id)); toast("✅ Ürün silindi"); fetchProducts(); }catch(e){ toast("❌ Silme hatası: "+e.message,true); } };
window.openEditProd=async id=>{
  const snap=await getDoc(rds("products",id)); if(!snap.exists()) return; const p=snap.data();
  const normCat=(p.category||p.cat||'Diğer').replace(/&amp;/g,'&').replace(/&#38;/g,'&').trim();
  document.getElementById('edit-id').value=id;
  document.getElementById('edit-name').value=p.name||p.n||'';
  document.getElementById('edit-name-en').value=p.nameEn||'';
  document.getElementById('edit-name-ar').value=p.nameAr||'';
  document.getElementById('edit-price').value=p.price||p.p||0;
  document.getElementById('edit-img').value=p.image||p.i||'';
  document.getElementById('edit-desc').value=p.description||'';
  // Kampanya
  document.getElementById('edit-campaign-price').value=p.campaignPrice||'';
  document.getElementById('edit-campaign-type').value=p.campaignType||'';
  document.getElementById('edit-campaign-date').value=p.campaignDate||'';
  toggleCampaignDate();
  updateCampaignPreview();
  const catSel=document.getElementById('edit-cat'); catSel.value=normCat;
  if(!catSel.value||catSel.value!==normCat) Array.from(catSel.options).forEach(o=>{ if(o.text.replace(/&amp;/g,'&').trim()===normCat) catSel.value=o.value; });
  editOptions=[...(p.options||[])]; renderOptTags(); openModal('prod-modal');
};

window.toggleCampaignDate=()=>{
  const type=document.getElementById('edit-campaign-type').value;
  document.getElementById('campaign-date-wrap').style.display = type==='date'?'':'none';
  updateCampaignPreview();
};

window.updateCampaignPreview=()=>{
  const price=document.getElementById('edit-campaign-price').value;
  const type=document.getElementById('edit-campaign-type').value;
  const date=document.getElementById('edit-campaign-date').value;
  const prev=document.getElementById('campaign-preview');
  if(!price||!type){ prev.style.display='none'; return; }
  let label='';
  if(type==='today') label='Bugüne özel';
  else if(type==='unlimited') label='Süresiz kampanya';
  else if(type==='date'&&date) label=`${new Date(date).toLocaleDateString('tr-TR')} tarihine kadar`;
  prev.style.display='block';
  prev.innerHTML=`👁 Görünüm: <s style="color:#aaa;">${document.getElementById('edit-price').value} TL</s> → <b style="color:#e65100;">${price} TL</b> <span style="background:#e65100;color:white;font-size:10px;padding:2px 6px;border-radius:10px;margin-left:4px;">${label}</span>`;
};

window.addOption=()=>{ const n=document.getElementById('opt-name').value.trim(), p=document.getElementById('opt-price').value; if(!n||!p) return; editOptions.push({name:n,price:Number(p)}); document.getElementById('opt-name').value=''; document.getElementById('opt-price').value=''; renderOptTags(); };
function renderOptTags(){ document.getElementById('opt-tags').innerHTML=editOptions.map((o,i)=>`<span class="opt-tag">${o.name} — ${o.price} TL<button onclick="removeOpt(${i})">×</button></span>`).join(''); }
window.removeOpt=i=>{ editOptions.splice(i,1); renderOptTags(); };

window.saveProduct=async()=>{
  const id=document.getElementById('edit-id').value, catVal=document.getElementById('edit-cat').value;
  const campaignPrice=document.getElementById('edit-campaign-price').value;
  const campaignType=document.getElementById('edit-campaign-type').value;
  const campaignDate=document.getElementById('edit-campaign-date').value;
  const today=new Date().toISOString().split('T')[0];
  // Kampanya geçerli mi?
  let activeCampaign=false;
  if(campaignPrice&&campaignType){
    if(campaignType==='today') activeCampaign = true; // günlük sıfırlama ayrıca yapılır
    else if(campaignType==='unlimited') activeCampaign=true;
    else if(campaignType==='date'&&campaignDate>=today) activeCampaign=true;
  }
  const data={
    name:document.getElementById('edit-name').value,
    nameEn:document.getElementById('edit-name-en').value||null,
    nameAr:document.getElementById('edit-name-ar').value||null,
    price:Number(document.getElementById('edit-price').value),
    category:catVal,
    image:document.getElementById('edit-img').value||null,
    description:document.getElementById('edit-desc').value||null,
    options:editOptions,
    campaignPrice:campaignPrice?Number(campaignPrice):null,
    campaignType:campaignType||null,
    campaignDate:campaignDate||null,
    campaignActive:activeCampaign
  };
  try{ await updateDoc(rds("products",id),data); toast("Güncellendi ✅"); closeModal('prod-modal'); fetchProducts(); }catch(e){ toast("❌ Hata: "+e.message); }
};

