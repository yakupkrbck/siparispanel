      }
      sendPushToCustomer(id, '❌ Siparişiniz İptal Edildi', 'Üzgünüz, siparişiniz iptal edildi.');
      scheduleCancelReminder(id);
    } else { toast("Güncellendi."); }
  }catch(e){ toast("❌ Hata: "+e.message,true); }
};

async function sendPushToCustomer(orderId, title, body) {
  if(!window.electronAPI) return; // Sadece Electron'da çalışır
  try {
    const orderDoc = await getDoc(rds("orders",orderId));
    if(!orderDoc.exists()) return;
    const order = orderDoc.data();
    const phone = order.phone;
    if(!phone) return;
    // Müşterinin FCM token'larını Firestore'dan al
    const q = query(rc("customers"), where("phone","==",phone));
    const snap = await getDocs(q);
    if(snap.empty) return;
    const custData = snap.docs[0].data();
    const tokens = custData.fcmTokenlar || custData.fcmTokens || (custData.fcmToken ? [custData.fcmToken] : []);
    if(!tokens.length) return;
    window.electronAPI.sendFcmPush(tokens, title, body);
    console.log(`📱 FCM push gönderildi: ${title} → ${tokens.length} token`);
  } catch(e) {
    console.error('sendPushToCustomer hata:', e.message);
  }
}
window.approve=async id=>{
  stopAlarm();
