.hbar-col{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;}
.hbar{width:100%;background:var(--primary);border-radius:3px 3px 0 0;min-height:2px;transition:height .4s;cursor:pointer;}
.hbar:hover{opacity:.8;}
.hbar-tt{position:absolute;top:-26px;left:50%;transform:translateX(-50%);background:#2c3e50;color:white;font-size:9px;padding:2px 5px;border-radius:3px;white-space:nowrap;display:none;z-index:5;}
.hbar:hover .hbar-tt{display:block;}
.hbar-lbl{font-size:9px;color:#bbb;margin-top:3px;text-align:center;}

/* Kurye panel section headers */
