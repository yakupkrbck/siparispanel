.anc-header{display:flex;align-items:center;gap:14px;padding:16px 20px;}
.anc-icon{font-size:26px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:#f8f9fa;border-radius:10px;flex-shrink:0;}
.anc-info{flex:1;}
.anc-title{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:3px;}
.anc-desc{font-size:11px;color:#7f8c8d;}
.anc-toggle{position:relative;width:46px;height:26px;flex-shrink:0;}
.anc-toggle input{opacity:0;width:0;height:0;}
.anc-slider{position:absolute;inset:0;background:#ccc;border-radius:26px;transition:.3s;cursor:pointer;}
.anc-slider:before{content:'';position:absolute;width:20px;height:20px;left:3px;top:3px;background:white;border-radius:50%;transition:.3s;}
.anc-toggle input:checked+.anc-slider{background:var(--success);}
.anc-toggle input:checked+.anc-slider:before{transform:translateX(20px);}
.anc-body{padding:0 20px 16px;border-top:1px solid #f5f5f5;}
