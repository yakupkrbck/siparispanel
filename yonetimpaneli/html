window.addPersonalCoupon = async () => {
  const phones  = window._personalSelectedCustomers;
  const code    = document.getElementById('personal-code').value.toUpperCase().trim();
  const type    = document.getElementById('personal-type').value;
  const val     = parseFloat(document.getElementById('personal-val').value);
  const minbasket = parseFloat(document.getElementById('personal-minbasket').value)||0;
  const expiry  = document.getElementById('personal-expiry').value||null;
  const res     = document.getElementById('personal-coupon-result');

  if(!phones.length){ toast('❌ En az bir müşteri seçin',true); return; }
  if(!code||!val){ toast('❌ Kod ve miktar zorunlu',true); return; }

  res.style.display='none';
  try {
    // Aynı kod var mı?
    const existing = await getDocs(query(rc("coupons"), where('code','==',code)));
    if(!existing.empty){ toast('❌ Bu kupon kodu zaten mevcut',true); return; }

    // Her müşteri için ayrı kupon oluştur (aynı kod, her biri kendi telefona bağlı)
    // Tek müşteri → tek kupon; çoklu → her birine farklı kod
    const results = [];
    for(let i=0; i<phones.length; i++) {
      const c = phones[i];
      const useCode = phones.length === 1 ? code : code + (i+1);
      // Duplicate kontrol (çoklu için)
      if(phones.length > 1) {
        const ex2 = await getDocs(query(rc("coupons"), where('code','==',useCode)));
        if(!ex2.empty){ results.push(`⚠️ ${useCode} zaten var, atlandı`); continue; }
      }
      await addDoc(rc("coupons"), {
        code: useCode, type, discount: val, condition: 'personal',
        forPhone: c.phone, forName: c.name,
        minBasket: minbasket, useLimit: 1, usedCount: 0,
        expiry: expiry||null, createdAt: new Date().toISOString()
      });
      results.push(`✅ <b>${c.name}</b> → <b>${useCode}</b>`);
    }

    res.style.display='block'; res.style.color='#27ae60';
    res.innerHTML = results.join('<br>');
    window._personalSelectedCustomers = [];
    document.getElementById('personal-phones-json').value = '[]';
    renderPersonalSelected();
    ['personal-code','personal-val','personal-minbasket','personal-expiry'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
    fetchCoupons();
  } catch(e){ toast('❌ Hata: '+e.message, true); }
};

