window.scheduleCancelReminder = async function scheduleCancelReminder(orderId) {
    const s = JSON.parse(localStorage.getItem(AN_KEY) || '{}');
    if(!s.cancel?.on || !window.electronAPI) return;
    setTimeout(async () => {
        try {
            const orderDoc = await getDoc(rds("orders",orderId));
            if(!orderDoc.exists()) return;
            const order = orderDoc.data();
            if(order.status !== 'İptal') return; // Hâlâ iptal durumundaysa gönder
            const phone = order.phone;
            if(!phone) return;
            const custSnap = await getDocs(query(rc("customers"), where('phone','==',phone)));
            if(custSnap.empty) return;
            const tokens = custSnap.docs[0].data().fcmTokenlar || custSnap.docs[0].data().fcmTokens || [];
            if(!tokens.length) return;
            await window.electronAPI.sendFcmPush(tokens, s.cancel.title, s.cancel.body);
            console.log('✅ İptal hatırlatma gönderildi:', phone);
        } catch(e) { console.error('Cancel reminder hata:', e); }
    }, 60 * 60 * 1000); // 1 saat
}

