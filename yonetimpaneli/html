// Gün değişince stokları sıfırla
async function resetDailyStock(){
  try{
    const today = new Date().toISOString().split('T')[0];
    const snap = await getDocs(query(rc("products"), where("inStock","==",false)));
    snap.forEach(async d=>{
      const data = d.data();
      if(data.stockOffDate && data.stockOffDate < today){
        await updateDoc(rds("products",d.id),{inStock:true, stockOffDate:null});
      }
    });
    // "Bugüne özel" kampanyaları sıfırla
    const campSnap = await getDocs(query(rc("products"), where("campaignType","==","today")));
    campSnap.forEach(async d=>{
      const data = d.data();
      // campaignDate bugünden önceyse kapat
      if(!data.campaignDate || data.campaignDate < today){
        await updateDoc(rds("products",d.id),{campaignActive:false});
      }
    });
  }catch(e){ console.log("Günlük sıfırlama hatası:",e); }
}

