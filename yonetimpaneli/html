function listenOrders(){
  const q = query(rc("orders"), orderBy("date","desc"));
  onSnapshot(q, snap=>{
    ['col-w','col-p','col-c'].forEach(id=>document.getElementById(id).innerHTML='');
    let wc=0; visibleOrders=[];
    const now=new Date();
    snap.docs.forEach(d=>{
      const o={id:d.id,...d.data()};
      if(o.status==='Teslim Edildi'||o.status==='İptal') return;
      if(o.date){ const od=o.date.toDate?o.date.toDate():new Date(o.date.seconds*1000); if((now-od)/3600000>24) return; }
      visibleOrders.push(o);
      if(o.status==='Onay Bekliyor') wc++;
      renderCard(o);
    });
    const b=document.getElementById('pbadge');
    b.innerText=wc; b.style.display=wc>0?'inline-block':'none';
    document.getElementById('cnt-w').innerText=wc;
    document.getElementById('cnt-p').innerText=document.getElementById('col-p').children.length;
    document.getElementById('cnt-c').innerText=document.getElementById('col-c').children.length;
    // Electron tepsisini güncelle
    if(window.electronAPI) window.electronAPI.updateBadge(wc);
    snap.docChanges().forEach(ch=>{
      if(ch.type==="added"&&!isFirst&&ch.doc.data().status==='Onay Bekliyor'){
        const orderData={id:ch.doc.id,...ch.doc.data()};
        playAlarm(); sendNotif(orderData); toast(`🔔 Yeni: ${orderData.customer}`);
      }
      // Müşteri iptal bildirimi
      if(ch.type==="modified"){
        const o={id:ch.doc.id,...ch.doc.data()};
        if(o.status==='İptal' && o.cancelledBy==='customer'){
          playCancelAlarm();
          toast(`⚠️ MÜŞTERİ İPTAL ETTİ: ${o.customer||o.phone} - Sipariş #${o.orderNumber||o.id.slice(-4)}`);
        }
      }
    });
    isFirst=false;
  });
}
function renderCard(o){
  const items=groupOrderItems(o.items||[]).map(g=>`<div>• ${g.qty > 1 ? `<b style="color:var(--primary);">${g.qty}×</b> ` : ''}<b>${g.n}</b>${g.note?` <span style="color:#999;font-size:11px;">(${g.note})</span>`:''}</div>`).join('');
  const addr=(o.addressDetails||o.address||'Adres Yok').substring(0,35);
  const note=o.orderNote?`<div class="onote">📝 ${o.orderNote}</div>`:'';
  const coupon=(o.coupon||o.discountCode)?`<span style="background:#e74c3c;color:white;font-size:10px;padding:2px 7px;border-radius:4px;font-weight:bold;margin-left:5px;">🏷️ %${o.discountRate||10}</span>`:'';
  const card=document.createElement('div'); card.className='ocard';
  let col='col-w', btns='';
  if(o.status==='Onay Bekliyor'){
    card.className+=' pend';
    btns=`<button class="btn" style="background:#c0392b" onclick="updStatus('${o.id}','İptal')">Reddet</button>
          <button class="btn" style="background:#27ae60" onclick="approve('${o.id}')">Onayla & Yazdır</button>`;
  } else if(o.status==='Hazırlanıyor'){
    col='col-p'; card.style.borderLeftColor='#e67e22';
    btns=`<button class="btn" style="background:#2c3e50" onclick="printOrd('${o.id}')">Yazdır</button>
          <button class="btn" style="background:#e67e22" onclick="updStatus('${o.id}','Yola Çıktı')">Yola Çıkar</button>`;
  } else if(o.status==='Yola Çıktı'){
    col='col-c'; card.style.borderLeftColor='#27ae60';
    btns=`<button class="btn" style="background:#27ae60" onclick="updStatus('${o.id}','Teslim Edildi')">Teslim Edildi</button>`;
  }
  const locBtn = o.customerLocation
    ? `<a href="https://www.google.com/maps?q=${o.customerLocation.lat},${o.customerLocation.lng}" target="_blank"
         style="display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#3498db;text-decoration:none;font-weight:700;background:#eaf4fd;padding:2px 8px;border-radius:6px;margin-top:2px;">
         📍 Konumu Gör ${o.customerLocation.acc?`<span style="color:#aaa;font-weight:400;">(±${o.customerLocation.acc}m)</span>`:''}
       </a>`
    : '';
  card.innerHTML=`
    <div class="ohead">
      <span class="cname">${o.customer} ${o.orderNumber?`<span style="background:#34495e;color:white;font-size:10px;padding:2px 6px;border-radius:10px;margin-left:4px;">#${o.orderNumber}</span>`:''}</span>
      <span class="oprice">${o.total} ₺${coupon}</span>
    </div>
    <div style="font-size:12px;color:#555;margin-bottom:3px;">📞 ${o.phone||'-'}</div>
