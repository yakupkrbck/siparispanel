<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mutfak Paneli</title>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{--sw:260px;--primary:#d35400;--dark:#2c3e50;--light:#ecf0f1;--success:#27ae60;--danger:#c0392b;--warn:#f39c12;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Roboto',sans-serif;background:var(--light);height:100vh;display:flex;overflow:hidden;}

/* LOGIN */
#login-overlay{position:fixed;inset:0;background:#2c3e50;z-index:9999;display:flex;align-items:center;justify-content:center;}
.login-box{background:white;border-radius:16px;padding:40px;width:320px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.4);}
.login-box h2{color:var(--primary);margin-bottom:5px;font-size:22px;}
.login-box p{color:#999;font-size:13px;margin-bottom:25px;}
.login-input{width:100%;padding:14px;border:2px solid #eee;border-radius:10px;font-size:18px;text-align:center;letter-spacing:6px;margin-bottom:15px;font-weight:bold;}
.login-input:focus{border-color:var(--primary);outline:none;}
.login-btn{width:100%;padding:14px;background:var(--primary);color:white;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;}
.login-error{color:var(--danger);font-size:13px;margin-top:10px;display:none;}

/* LAYOUT */
aside{width:var(--sw);background:var(--dark);color:white;display:flex;flex-direction:column;padding:20px 0;flex-shrink:0;overflow-y:auto;height:100vh;}
.brand{text-align:center;font-size:22px;font-weight:800;margin-bottom:20px;color:var(--primary);}
.brand span{color:#bdc3c7;font-size:13px;display:block;margin-top:4px;font-weight:300;}
.store-ctrl{padding:15px 20px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:10px;text-align:center;}
.store-ctrl-title{font-size:11px;color:#95a5a6;margin-bottom:8px;font-weight:bold;letter-spacing:1px;}
.store-btn-group{display:flex;gap:10px;}
.sbtn{flex:1;padding:8px;border:none;border-radius:4px;cursor:pointer;font-weight:bold;font-size:12px;color:white;transition:.2s;}
.sbtn.open{background:#27ae60;opacity:.3;} .sbtn.close{background:#c0392b;opacity:.3;}
.sbtn.open.on{opacity:1;box-shadow:0 0 10px rgba(39,174,96,.5);} .sbtn.close.on{opacity:1;box-shadow:0 0 10px rgba(192,57,43,.5);}
.mi{padding:10px 18px;cursor:pointer;transition:.3s;color:#bdc3c7;display:flex;align-items:center;gap:10px;font-size:12.5px;border-left:4px solid transparent;}
.mi:hover,.mi.active{background:rgba(255,255,255,.05);color:white;border-left-color:var(--primary);}
.badge{background:var(--danger);color:white;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:bold;margin-left:auto;display:none;}
main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
header{background:white;padding:14px 28px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 2px 5px rgba(0,0,0,.05);}
.page-title{font-size:20px;font-weight:600;color:var(--dark);}
.sys-status{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:700;padding:8px 18px;border-radius:20px;transition:.3s;}
.sys-status.open{background:#e8f8f5;color:var(--success);border:1px solid #d4efdf;}
.sys-status.closed{background:#fdedec;color:var(--danger);border:1px solid #fadbd8;}
.sdot{width:10px;height:10px;border-radius:50%;}
.sys-status.open .sdot{background:var(--success);animation:pulse 2s infinite;}
.sys-status.closed .sdot{background:var(--danger);}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(39,174,96,.7);}100%{box-shadow:0 0 0 10px rgba(39,174,96,0);}}

/* TABS */
.tab{display:none;padding:18px;height:100%;overflow-y:auto;}
.tab.active{display:block;}

/* KANBAN */
.kanban{display:flex;gap:16px;height:100%;padding-bottom:16px;}
.kcol{flex:1;background:#dfe6e9;border-radius:10px;display:flex;flex-direction:column;min-width:280px;border:1px solid #ced6e0;}
.khead{padding:14px;font-weight:700;text-transform:uppercase;background:#fff;border-radius:10px 10px 0 0;display:flex;justify-content:space-between;border-bottom:2px solid transparent;}
.kbody{flex:1;overflow-y:auto;padding:10px;}
.ocard{background:white;border-radius:8px;padding:14px;margin-bottom:10px;box-shadow:0 2px 3px rgba(0,0,0,.05);border-left:5px solid #ccc;}
.ocard.pend{border-left-color:var(--danger);background:#fff5f5;animation:flash 1.5s infinite;}
@keyframes flash{0%{border-left-color:var(--danger);background:#fff5f5;}50%{border-left-color:var(--warn);background:#ffffec;}100%{border-left-color:var(--danger);background:#fff5f5;}}
.ohead{display:flex;justify-content:space-between;margin-bottom:7px;align-items:center;flex-wrap:wrap;gap:5px;}
.cname{font-weight:700;font-size:15px;color:#2c3e50;}
.oprice{font-weight:800;color:var(--primary);font-size:17px;}
.oitems{font-size:13px;color:#555;margin:8px 0;border-top:1px dashed #eee;padding-top:7px;}
.onote{font-size:12px;color:#888;font-style:italic;background:#fffbe6;padding:5px 8px;border-radius:6px;margin-top:5px;}
.bgrp{display:flex;gap:7px;margin-top:9px;}
.btn{flex:1;border:none;padding:11px;border-radius:6px;cursor:pointer;font-weight:600;color:white;font-size:13px;transition:.2s;}
.btn:hover{opacity:.9;}

/* TABLE */
.dtbl{width:100%;border-collapse:collapse;background:white;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);}
.dtbl th{background:var(--dark);color:white;padding:12px;text-align:left;font-size:13px;}
.dtbl td{padding:11px 12px;border-bottom:1px solid #f0f0f0;vertical-align:middle;font-size:13px;}
.dtbl tr:hover td{background:#fafafa;}
.pinput{width:75px;padding:5px 8px;border:1px solid #ccc;border-radius:4px;font-weight:bold;font-size:13px;}
.switch{position:relative;display:inline-block;width:46px;height:22px;}
.switch input{opacity:0;width:0;height:0;}
.slider{position:absolute;cursor:pointer;inset:0;background:#ccc;transition:.4s;border-radius:34px;}
.slider:before{position:absolute;content:"";height:14px;width:14px;left:4px;bottom:4px;background:white;transition:.4s;border-radius:50%;}
input:checked+.slider{background:#27ae60;}
input:checked+.slider:before{transform:translateX(24px);}

/* FORM */
.mform{background:#f8f9fa;padding:14px;border-radius:8px;margin-bottom:18px;border:1px solid #e1e1e1;display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;}
.fg{flex:1;min-width:130px;}
.fg label{display:block;font-size:11px;font-weight:bold;color:#7f8c8d;margin-bottom:4px;text-transform:uppercase;}
.fg input,.fg select,.fg textarea{width:100%;padding:9px;border:1px solid #ddd;border-radius:5px;font-size:13px;font-family:inherit;}
.fg textarea{resize:vertical;min-height:60px;}

/* KUPON */
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;}
.ccard{background:white;border:1px solid #ddd;border-radius:8px;padding:14px 14px 14px 18px;position:relative;border-left:5px solid var(--primary);overflow:hidden;}
.ccard.expired{border-left-color:#bbb;opacity:.7;}
.ccard.expiring{border-left-color:var(--warn);}
.ccode{font-size:18px;font-weight:800;color:#2c3e50;font-family:'Courier Prime',monospace;letter-spacing:1px;}
.cdel{position:absolute;top:10px;right:10px;color:var(--danger);cursor:pointer;background:white;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 5px rgba(0,0,0,.15);border:1px solid #eee;transition:.2s;z-index:2;}
.cdel:hover{background:var(--danger);color:white;}
.coupon-badge{display:inline-block;font-size:10px;padding:2px 8px;border-radius:10px;font-weight:bold;margin-top:4px;}
.coupon-badge.active{background:#e8f8f5;color:#27ae60;}
.coupon-badge.expired{background:#fdedec;color:#c0392b;}
.coupon-badge.expiring{background:#fef9e7;color:#f39c12;}

/* PUAN */
.points-badge{display:inline-flex;align-items:center;gap:4px;background:linear-gradient(135deg,#f39c12,#e67e22);color:white;padding:3px 10px;border-radius:12px;font-size:12px;font-weight:700;}

/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:4000;align-items:center;justify-content:center;padding:20px;}
.modal-bg.open{display:flex;}
.modal-box{background:white;border-radius:16px;width:100%;max-width:520px;max-height:88vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3);padding:28px;}
.modal-box h3{margin:0 0 18px;color:var(--dark);font-size:18px;border-bottom:2px solid var(--primary);padding-bottom:10px;display:flex;justify-content:space-between;align-items:center;}
.modal-close{background:none;border:none;font-size:22px;cursor:pointer;color:#aaa;line-height:1;flex-shrink:0;}
.modal-close:hover{color:#333;}

/* SÜRÜKLE-BIRAK */
.drag-row{cursor:grab;} .drag-row:active{cursor:grabbing;}
.drag-row.dragging{opacity:.4;background:#fff3e0!important;}
.drag-over td{border-top:3px solid var(--primary)!important;}

/* SEÇENEK ETİKETİ */
.opt-tag{display:inline-flex;align-items:center;gap:5px;background:#eee;border-radius:20px;padding:3px 10px;font-size:12px;margin:3px;}
.opt-tag button{background:none;border:none;cursor:pointer;color:#c0392b;font-size:14px;line-height:1;}

/* KARA LİSTE */
.blacklist-badge{background:#c0392b;color:white;font-size:10px;padding:2px 7px;border-radius:10px;font-weight:bold;}

/* TOAST */
#toast-c{position:fixed;top:18px;right:18px;z-index:5000;}
.toast{background:white;padding:13px 18px;border-radius:8px;box-shadow:0 5px 20px rgba(0,0,0,.15);margin-bottom:8px;border-left:5px solid var(--success);animation:si .3s;}
.toast.err{border-left-color:var(--danger);}
@keyframes si{from{transform:translateX(100%);}to{transform:translateX(0);}}

/* SİPARİŞ POPUP */
#order-popup-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99998;backdrop-filter:blur(4px);}
#order-popup-overlay.show{display:flex;align-items:center;justify-content:center;}
#order-popup{background:white;border-radius:24px;box-shadow:0 30px 80px rgba(0,0,0,.4);width:420px;max-width:95vw;animation:popIn .4s cubic-bezier(.34,1.56,.64,1);overflow:hidden;}
@keyframes popIn{from{transform:scale(.7);opacity:0;}to{transform:scale(1);opacity:1;}}
.popup-header{background:linear-gradient(135deg,#c0392b,#e74c3c);color:white;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;}
.popup-header-left{display:flex;align-items:center;gap:12px;}
.popup-bell{width:44px;height:44px;background:rgba(255,255,255,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;animation:bellRing 1s ease infinite;}
@keyframes bellRing{0%,100%{transform:rotate(0);}20%{transform:rotate(-15deg);}40%{transform:rotate(15deg);}60%{transform:rotate(-8deg);}80%{transform:rotate(8deg);}}
.popup-header-title{font-size:16px;font-weight:800;letter-spacing:.5px;}
.popup-header-sub{font-size:12px;opacity:.8;margin-top:2px;}
.popup-close{background:rgba(255,255,255,.2);border:none;color:white;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:20px;font-weight:bold;transition:.2s;line-height:1;}
.popup-close:hover{background:rgba(255,255,255,.35);}
.popup-body{padding:24px;}
.popup-customer{font-size:22px;font-weight:800;color:var(--dark);margin-bottom:4px;}
.popup-phone{font-size:13px;color:#95a5a6;margin-bottom:16px;display:flex;align-items:center;gap:5px;}
.popup-items{background:#fdf6ec;padding:14px;border-radius:12px;margin-bottom:14px;border-left:4px solid var(--warn);}
.popup-item{font-size:14px;color:#444;margin-bottom:5px;font-weight:600;display:flex;align-items:center;gap:6px;}
.popup-item:last-child{margin-bottom:0;}
.popup-addr{background:#f8f9fa;padding:10px 14px;border-radius:10px;font-size:13px;color:#555;margin-bottom:14px;display:flex;align-items:flex-start;gap:8px;}
.popup-total-row{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-top:2px dashed #eee;margin-bottom:18px;}
.popup-total-lbl{font-size:13px;color:#95a5a6;font-weight:600;}
.popup-total{font-size:32px;font-weight:900;color:var(--primary);}
.popup-actions{display:flex;gap:12px;}
.popup-btn{flex:1;padding:15px;border:none;border-radius:14px;cursor:pointer;font-weight:800;font-size:15px;transition:all .2s;letter-spacing:.3px;}
.popup-btn:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(0,0,0,.15);}
.popup-btn:active{transform:translateY(0);}
.popup-btn.reject{background:#f0f0f0;color:#777;}
.popup-btn.reject:hover{background:#e0e0e0;}
.popup-btn.approve{background:linear-gradient(135deg,#27ae60,#2ecc71);color:white;box-shadow:0 4px 15px rgba(39,174,96,.4);}

/* KATEGORİ BAŞLIĞI */
.cat-header td{background:#34495e;color:white;font-weight:700;padding:9px 12px;font-size:12px;letter-spacing:1px;text-transform:uppercase;}

/* KUPON TAVSİYELERİ */
.tip-card{background:white;border:1px solid #e1e1e1;border-radius:10px;padding:14px;border-left:4px solid var(--primary);}
.tip-card h5{font-size:13px;color:var(--dark);margin-bottom:4px;}
.tip-card p{font-size:12px;color:#7f8c8d;line-height:1.5;}

/* RAPORLAMA */
.stat-card{background:white;border-radius:12px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,.06);border-top:4px solid var(--primary);}
.stat-val{font-size:32px;font-weight:800;color:var(--dark);margin:8px 0 4px;}
.stat-lbl{font-size:12px;color:#95a5a6;font-weight:600;text-transform:uppercase;letter-spacing:.5px;}
.stat-sub{font-size:13px;color:#7f8c8d;margin-top:4px;}
.chart-bar-wrap{display:flex;align-items:flex-end;gap:6px;height:120px;margin-top:10px;}
.chart-bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;}
.chart-bar{width:100%;background:var(--primary);border-radius:4px 4px 0 0;transition:height .4s ease;min-height:2px;cursor:pointer;position:relative;}
.chart-bar:hover{opacity:.8;}
.chart-bar-tooltip{position:absolute;top:-28px;left:50%;transform:translateX(-50%);background:#2c3e50;color:white;font-size:10px;padding:2px 6px;border-radius:4px;white-space:nowrap;display:none;}
.chart-bar:hover .chart-bar-tooltip{display:block;}
.chart-bar-lbl{font-size:10px;color:#95a5a6;text-align:center;}
.prod-rank{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #f5f5f5;}
.prod-rank:last-child{border-bottom:none;}
.prod-rank-num{width:24px;height:24px;border-radius:50%;background:var(--primary);color:white;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.prod-rank-bar{flex:1;height:8px;background:#ecf0f1;border-radius:4px;overflow:hidden;}
.prod-rank-fill{height:100%;background:linear-gradient(90deg,var(--primary),#e67e22);border-radius:4px;transition:width .5s ease;}
.hour-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:4px;margin-top:10px;}
.hour-cell{aspect-ratio:1;border-radius:4px;background:#ecf0f1;display:flex;align-items:center;justify-content:center;font-size:9px;color:#7f8c8d;cursor:pointer;transition:.2s;position:relative;}
.hour-cell:hover .hour-tooltip{display:block;}
.hour-tooltip{display:none;position:absolute;bottom:110%;left:50%;transform:translateX(-50%);background:#2c3e50;color:white;font-size:10px;padding:3px 7px;border-radius:4px;white-space:nowrap;z-index:10;}

/* MOBİL UYUMLULUK */
@media(max-width:900px){
  .rpt-grid{grid-template-columns:1fr!important;}
}
/* RAPOR HAZIR BUTONLAR */
.rpt-qbtn{padding:7px 14px;border:1px solid #ddd;border-radius:20px;background:white;cursor:pointer;font-size:12px;font-weight:600;color:#555;transition:.2s;}
.rpt-qbtn:hover{border-color:var(--primary);color:var(--primary);}
.rpt-qbtn.active{background:var(--primary);color:white;border-color:var(--primary);}

/* PRINT */
#print-area{display:none;}
@media print{
  aside,header,.tab,#toast-c,.bgrp,#login-overlay{display:none!important;}
  body,main{background:white;height:auto;overflow:visible;display:block;}
  #print-area{display:block!important;width:80mm;margin:0;padding:8px;font-family:'Courier Prime',monospace;font-size:12px;}
  .rh{text-align:center;font-weight:bold;margin-bottom:8px;border-bottom:2px dashed black;padding-bottom:5px;}
  .ri{margin-bottom:8px;font-size:11px;}
  .rit{border-bottom:1px dashed black;padding-bottom:4px;margin-bottom:4px;}
  .rrow{display:flex;justify-content:space-between;margin-bottom:3px;}
  .rtot{text-align:right;font-size:15px;font-weight:bold;margin-top:8px;}
  .rf{text-align:center;margin-top:16px;font-size:10px;}
}

/* ══════════════════════════════════════════════
   KURYE PANELİ STİLLERİ
══════════════════════════════════════════════ */

/* Harita alanı */
#courier-map{
  width:100%;height:420px;border-radius:14px;
  background:#1a1a2e;
  position:relative;overflow:hidden;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
  margin-bottom:20px;
}
#courier-map iframe{width:100%;height:100%;border:none;border-radius:14px;}
.map-overlay{
  position:absolute;top:0;left:0;right:0;bottom:0;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:12px;color:#bdc3c7;
  background:linear-gradient(135deg,#1a1a2e,#16213e);
}
.map-overlay-icon{font-size:52px;opacity:.5;}
.map-overlay-text{font-size:14px;font-weight:600;opacity:.6;text-align:center;line-height:1.6;}

/* Kurye durum kartları */
.courier-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:14px;margin-bottom:24px;
}
.courier-stat{
  background:white;border-radius:12px;padding:18px;
  box-shadow:0 2px 8px rgba(0,0,0,.06);
  border-left:5px solid #ddd;
  display:flex;align-items:center;gap:14px;
  transition:transform .2s;cursor:default;
}
.courier-stat:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(0,0,0,.1);}
.courier-stat-icon{font-size:32px;flex-shrink:0;}
.courier-stat-val{font-size:28px;font-weight:800;color:var(--dark);line-height:1;}
.courier-stat-lbl{font-size:11px;color:#95a5a6;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-top:3px;}

/* Aktif teslimat kartları */
.delivery-card{
  background:white;border-radius:12px;padding:18px;
  margin-bottom:12px;
  box-shadow:0 2px 8px rgba(0,0,0,.06);
  border-left:5px solid var(--success);
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:14px;align-items:center;
}
.delivery-card.late-risk{border-left-color:var(--warn);}
.delivery-card.late{border-left-color:var(--danger);}
.delivery-num{
  width:40px;height:40px;border-radius:50%;
  background:var(--dark);color:white;
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:16px;flex-shrink:0;
}
.delivery-name{font-weight:700;font-size:15px;color:var(--dark);}
.delivery-addr{font-size:12px;color:#7f8c8d;margin-top:3px;}
.delivery-time{text-align:right;}
.delivery-elapsed{font-size:18px;font-weight:800;color:var(--dark);}
.delivery-status-badge{
  font-size:11px;font-weight:700;padding:3px 10px;
  border-radius:20px;margin-top:4px;display:inline-block;
}
.badge-ok{background:#e8f8f5;color:var(--success);}
.badge-risk{background:#fef9e7;color:var(--warn);}
.badge-late{background:#fdedec;color:var(--danger);}

/* Performans tablosu */
.perf-table{width:100%;border-collapse:collapse;background:white;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);}
.perf-table th{background:#2c3e50;color:white;padding:12px 14px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.5px;}
.perf-table td{padding:12px 14px;border-bottom:1px solid #f5f5f5;font-size:13px;}
.perf-table tr:last-child td{border-bottom:none;}
.perf-table tr:hover td{background:#fafafa;}
.perf-bar-wrap{display:flex;align-items:center;gap:8px;}
.perf-bar-bg{flex:1;height:6px;background:#ecf0f1;border-radius:3px;overflow:hidden;}
.perf-bar-fill{height:100%;border-radius:3px;transition:width .5s ease;}

/* Yoğunluk haritası - mahalle */
.zone-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-top:14px;}
.zone-card{
  background:white;border-radius:10px;padding:14px;
  box-shadow:0 2px 6px rgba(0,0,0,.06);
