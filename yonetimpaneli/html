const PR_KEY = 'printerSettings';

function getPrinterSettings() {
  const defaults = {
    width: '76', margin: '2', lineheight: '1.55',
    font: "'Courier New',Courier,monospace", fontsize: '12',
    itemweight: '700', totalsize: '15',
    boldInfo: false, darkTotal: true,
    brand: 'DONERCI ISMAIL', subtitle: 'KARACABEY',
    footer1: 'Tel: 0224 246 61 20', footer2: 'donercismail.com',
    closing: 'Afiyet Olsun!', tag: '** ONLINE SIPARIS **',
    brandsize: '17'
  };
  try {
    const saved = localStorage.getItem(PR_KEY);
    return saved ? { ...defaults, ...JSON.parse(saved) } : defaults;
  } catch(_) { return defaults; }
}

window.loadPrinterSettings = () => {
  const s = getPrinterSettings();
  const fields = ['width','margin','lineheight','font','fontsize','itemweight','totalsize','brand','subtitle','footer1','footer2','closing','tag','brandsize'];
  fields.forEach(f => {
    const el = document.getElementById('pr-'+f);
    if(el) el.value = s[f] ?? el.value;
  });
  const boldEl = document.getElementById('pr-bold-info');
  const darkEl = document.getElementById('pr-dark-total');
  if(boldEl) boldEl.checked = !!s.boldInfo;
  if(darkEl) darkEl.checked = s.darkTotal !== false;
};

window.savePrinterSettings = () => {
  const fields = ['width','margin','lineheight','font','fontsize','itemweight','totalsize','brand','subtitle','footer1','footer2','closing','tag','brandsize'];
  const s = {};
  fields.forEach(f => { const el = document.getElementById('pr-'+f); if(el) s[f] = el.value; });
  s.boldInfo  = document.getElementById('pr-bold-info')?.checked || false;
  s.darkTotal = document.getElementById('pr-dark-total')?.checked !== false;
  localStorage.setItem(PR_KEY, JSON.stringify(s));
};

