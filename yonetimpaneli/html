let currentPopupOrder = null;
// Aynı ürünleri gruplandır: [{n:'Lahmacun',qty:6,...}]
function groupOrderItems(items) {
  const map = {};
  (items||[]).forEach(i => {
    const key = (i.n||'') + '|' + (i.note||'');
    if(map[key]) { map[key].qty++; }
    else { map[key] = {...i, qty: 1}; }
  });
  return Object.values(map);
}

window.showOrderPopup = (order) => {
  currentPopupOrder = order;
  const items = groupOrderItems(order.items||[]).map(g=>
