window.sendTelafiCoupon = async () => {
  const phone      = document.getElementById('telafi-phone').value;
  const name       = document.getElementById('telafi-customer-name').innerText.split('(')[0].trim();
  const message    = document.getElementById('telafi-message').value.trim();
  const viaSms     = document.getElementById('telafi-method-sms').checked;
  const viaPush    = document.getElementById('telafi-method-push').checked;
  const res        = document.getElementById('telafi-result');
  const btn        = document.getElementById('telafi-send-btn');
  const isKupon    = document.getElementById('telafi-section-kupon').style.display !== 'none';

  if(!viaSms && !viaPush){ toast('❌ En az bir gönderim yöntemi seçin',true); return; }

  btn.disabled = true; btn.innerText = 'Gönderiliyor...';
  res.style.display = 'none';

  try {
    const complaintId = document.getElementById('telafi-complaint-id').value;
    let resultLines = [];

    if(isKupon) {
      // ── KUPON YOLU ──
      const type      = document.getElementById('telafi-type').value;
      const val       = parseFloat(document.getElementById('telafi-val').value);
      const minbasket = parseFloat(document.getElementById('telafi-minbasket').value)||0;
      const expiry    = document.getElementById('telafi-expiry').value||null;
      if(!val){ toast('❌ İndirim miktarı girin',true); btn.disabled=false; btn.innerText='📤 Gönder'; return; }

      const code = 'TELAFI' + Math.random().toString(36).substring(2,6).toUpperCase();
      await addDoc(rc("coupons"), {
        code, type, discount: val, condition: 'personal',
        forPhone: phone, forName: name,
        minBasket: minbasket, useLimit: 1, usedCount: 0,
        expiry: expiry||null, createdAt: new Date().toISOString(), isTelafi: true
      });
      resultLines.push(`🎟 Kupon: <b>${code}</b> (${type==='percent'?`%${val}`:`${val} TL`})`);

      const fullMsg = message + (message ? `\nKupon kodunuz: ${code}` : `Kupon kodunuz: ${code}`);

      if(viaSms) {
        const smsResp = await fetch('https://netgsm-otp.donerciismal.workers.dev/', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ phone, message: fullMsg + ' - Dönerci İsmail' })
        });
        const smsData = await smsResp.json();
        resultLines.push(smsData.code==='00'||smsData.success ? '📱 SMS gönderildi' : '⚠️ SMS gönderilemedi');
      }
      if(viaPush) {
        const custSnap = await getDocs(query(rc("customers"), where('phone','==',phone)));
        if(!custSnap.empty) {
          const tokens = (custSnap.docs[0].data().fcmTokenlar||custSnap.docs[0].data().fcmTokens||[]).filter(Boolean);
          if(tokens.length && window.electronAPI) {
            window.electronAPI.sendFcmPush(tokens, '🎁 Size özel sürpriz!', fullMsg);
            resultLines.push('🔔 Push gönderildi');
          } else resultLines.push('⚠️ Push: cihaz token bulunamadı');
        }
      }
      fetchCoupons();
    } else {
      // ── PUAN YOLU ──
      const pts = parseInt(document.getElementById('telafi-points').value);
      if(!pts||pts<1){ toast('❌ Puan miktarı girin',true); btn.disabled=false; btn.innerText='📤 Gönder'; return; }

      const custSnap = await getDocs(query(rc("customers"), where('phone','==',phone)));
      if(custSnap.empty){ toast('❌ Müşteri bulunamadı',true); btn.disabled=false; btn.innerText='📤 Gönder'; return; }
      await updateDoc(custSnap.docs[0].ref, { loyaltyPoints: increment(pts) });
      resultLines.push(`⭐ <b>${pts} puan</b> hesaba eklendi`);

      const ptsMsg = message + (message ? `\n${pts} puan hesabınıza eklendi.` : `${pts} puan hesabınıza eklendi.`);

      if(viaSms) {
        const smsResp = await fetch('https://netgsm-otp.donerciismal.workers.dev/', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ phone, message: ptsMsg + ' - Dönerci İsmail' })
        });
        const smsData = await smsResp.json();
        resultLines.push(smsData.code==='00'||smsData.success ? '📱 SMS gönderildi' : '⚠️ SMS gönderilemedi');
      }
      if(viaPush) {
        const tokens = (custSnap.docs[0].data().fcmTokenlar||custSnap.docs[0].data().fcmTokens||[]).filter(Boolean);
        if(tokens.length && window.electronAPI) {
          window.electronAPI.sendFcmPush(tokens, '⭐ Puan Kazandınız!', ptsMsg);
          resultLines.push('🔔 Push gönderildi');
        } else resultLines.push('⚠️ Push: cihaz token bulunamadı');
      }
    }

    // Şikayeti çözüldü işaretle
    if(complaintId) {
      await updateDoc(rds("complaints",complaintId), {
        status:'resolved', resolvedAt: new Date(),
        telafiType: isKupon ? 'coupon' : 'points'
      });
    }

    res.style.display='block'; res.style.color='#27ae60';
    res.innerHTML = '✅ ' + resultLines.join('<br>');
    btn.innerText = '✅ Gönderildi';
    toast(`🎁 Telafi gönderildi → ${name}`);
    setTimeout(() => { closeModal('telafi-modal'); loadComplaints(); }, 2500);

  } catch(e) {
    res.style.display='block'; res.style.color='#c0392b';
    res.innerText = '❌ Hata: ' + e.message;
    btn.disabled=false; btn.innerText='📤 Gönder';
  }
};

