window.runAutoNotifs = async function runAutoNotifs(manual=false) {
    if(!window.electronAPI) { if(manual) toast('⚠️ Sadece Electron panelde çalışır!', true); return; }
    const s = JSON.parse(localStorage.getItem(AN_KEY) || '{}');
    const now = new Date();
    let totalSent = 0;

    // Yardımcı: timestamp → Date güvenli dönüşüm
    function toDate(val) {
        if(!val) return null;
        if(val.toDate) return val.toDate(); // Firestore Timestamp
        if(val instanceof Date) return val;
        if(typeof val === 'string') return new Date(val);
        return null;
    }

    // Yardımcı: son bildirim zamanını güncelle (hata sessizce yutulsun)
    async function markNotifSent(collection_name, docId, field) {
        try { await setDoc(doc(db, collection_name, docId), { [field]: new Date() }, { merge:true }); } catch(e) {}
    }

    // 1. GERİ KAZANMA
    if(s.winback?.on) {
        try {
            const days = Math.max(3, parseInt(s.winback.days)||14);
            const cutoff = new Date(now - days*24*60*60*1000);
            const snap = await getDocs(rc("customers"));
            for(const d of snap.docs) {
                const cust = d.data();
                const lastOrder = toDate(cust.lastOrderDate);
                if(!lastOrder || lastOrder >= cutoff) continue; // Hiç sipariş yok veya son sipariş taze
                const tokens = (cust.fcmTokenlar || cust.fcmTokens || []).filter(Boolean);
                if(!tokens.length) continue;
                const lastSent = toDate(cust.lastWinbackNotif);
                if(lastSent && (now - lastSent) < 7*24*60*60*1000) continue; // 7 günde bir max
                await window.electronAPI.sendFcmPush(tokens, s.winback.title||'Sizi özledik! 🥙', s.winback.body||'Tekrar sipariş vermek ister misiniz?');
                await markNotifSent('phone_customers', d.id, 'lastWinbackNotif');
                totalSent++;
                await new Promise(r => setTimeout(r, 200)); // Rate limit için küçük bekleme
            }
            document.getElementById('an-winback-last').textContent = `Son çalışma: ${now.toLocaleTimeString('tr-TR')}`;
        } catch(e) { console.error('Winback hata:', e.message); }
    }

    // 2. PUAN HATIRLATMA
    if(s.points?.on) {
        try {
            const minPts = Math.max(50, parseInt(s.points.min)||100);
            const snap = await getDocs(rc("customers"));
            for(const d of snap.docs) {
                const cust = d.data();
                const pts = parseInt(cust.loyaltyPoints || cust.points || 0);
                if(pts < minPts) continue;
                const tokens = (cust.fcmTokenlar || cust.fcmTokens || []).filter(Boolean);
                if(!tokens.length) continue;
                const lastSent = toDate(cust.lastPointsNotif);
                if(lastSent && (now - lastSent) < 30*24*60*60*1000) continue; // Ayda bir max
                const bodyText = `${pts} puanın var! ${s.points.body||'Kullanmayı unutma!'}`;
                await window.electronAPI.sendFcmPush(tokens, s.points.title||'Puanların sizi bekliyor! ⭐', bodyText);
                await markNotifSent('phone_customers', d.id, 'lastPointsNotif');
                totalSent++;
                await new Promise(r => setTimeout(r, 200));
            }
            document.getElementById('an-points-last').textContent = `Son çalışma: ${now.toLocaleTimeString('tr-TR')}`;
        } catch(e) { console.error('Points notif hata:', e.message); }
    }

    // 3. ÖĞLE PAZARLAMA (günde 1 kez, belirlenen saatte)
    if(s.lunch?.on) {
        try {
            const [lh, lm] = (s.lunch.time||'11:30').split(':').map(Number);
            const isLunchHour = now.getHours() === lh;
            const today = now.toDateString();
            const lastLunch = localStorage.getItem('lastLunchNotif');
            const alreadySentToday = lastLunch === today;

            if((isLunchHour && !alreadySentToday) || manual) {
                if(!alreadySentToday || manual) {
                    const snap = await getDocs(rc("customers"));
                    const tokens = [];
                    snap.forEach(d => {
                        const t = (d.data().fcmTokenlar || d.data().fcmTokens || []).filter(Boolean);
                        tokens.push(...t);
                    });
                    const uniqueTokens = [...new Set(tokens)];
                    if(uniqueTokens.length) {
                        for(let i=0; i<uniqueTokens.length; i+=50) {
                            await window.electronAPI.sendFcmPush(uniqueTokens.slice(i,i+50), s.lunch.title||'Öğle yemeği vakti! 🥙', s.lunch.body||'Lezzetli döner siparişin hazır!');
                            await new Promise(r => setTimeout(r, 300));
                        }
                        if(!manual) localStorage.setItem('lastLunchNotif', today); // Manuel testte tekrar göndermeyi engelleme
                        totalSent += uniqueTokens.length;
                    }
                }
            }
            document.getElementById('an-lunch-last').textContent = `Son çalışma: ${now.toLocaleTimeString('tr-TR')}`;
        } catch(e) { console.error('Lunch notif hata:', e.message); }
    }

    // 4. TESLİM SONRASI DEĞERLENDİRME (30-60 dk arası teslim edilmiş siparişler)
    if(s.review?.on) {
        try {
            const sixtyMinsAgo  = new Date(now - 60*60*1000);
            const thirtyMinsAgo = new Date(now - 30*60*1000);
            // Son 2 saatin siparişlerini çek (performans için limit)
            const twoHoursAgo = new Date(now - 2*60*60*1000);
            const snap = await getDocs(query(
                rc("orders"),
                where('status','==','Teslim Edildi'),
                where('deliveredAt','>=', twoHoursAgo)
            ));
            for(const d of snap.docs) {
                const order = d.data();
                if(order.reviewNotifSent) continue;
                const deliveredAt = toDate(order.deliveredAt);
                if(!deliveredAt) continue;
                if(deliveredAt > thirtyMinsAgo || deliveredAt < sixtyMinsAgo) continue; // 30-60 dk arası
                const phone = order.phone;
                if(!phone) continue;
                const custSnap = await getDocs(query(rc("customers"), where('phone','==',phone)));
                if(custSnap.empty) continue;
                const tokens = (custSnap.docs[0].data().fcmTokenlar || custSnap.docs[0].data().fcmTokens || []).filter(Boolean);
                if(!tokens.length) continue;
                await window.electronAPI.sendFcmPush(tokens, s.review.title||'Siparişiniz nasıldı? ⭐', s.review.body||'Deneyiminizi değerlendirin!');
                await setDoc(rds("orders",d.id), { reviewNotifSent: true }, { merge:true });
                totalSent++;
            }
            document.getElementById('an-review-last').textContent = `Son çalışma: ${now.toLocaleTimeString('tr-TR')}`;
        } catch(e) { console.error('Review notif hata:', e.message); }
    }

    // Durum güncelle
    const statusEl = document.getElementById('auto-notif-status');
    if(statusEl) statusEl.textContent = `Son kontrol: ${now.toLocaleTimeString('tr-TR')} — ${totalSent} bildirim gönderildi`;
    if(manual && totalSent > 0) toast(`✅ ${totalSent} bildirim gönderildi`);
    else if(manual) toast('ℹ️ Koşulu sağlayan müşteri bulunamadı');
}

