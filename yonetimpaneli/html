}

window._selectedPushCustomers = []; // { phone, name, tokens }
window._allPushCustomers = null; // cache

window.searchPushCustomers = async function searchPushCustomers(q) {
    const resultsEl = document.getElementById('push-customer-results');
    if(!q || q.length < 2) { resultsEl.style.display = 'none'; return; }

    // Müşterileri cache'le
    if(!window._allPushCustomers) {
        try {
            const snap = await getDocs(rc("customers"));
            window._allPushCustomers = snap.docs.map(d => ({ id: d.id, ...d.data() }));
        } catch(e) { return; }
    }

    const lower = q.toLowerCase();
    const matches = window._allPushCustomers.filter(c =>
        (c.phone||'').includes(q) ||
        (c.name||'').toLowerCase().includes(lower)
    ).slice(0, 8);

    if(!matches.length) {
        resultsEl.innerHTML = '<div style="padding:12px;color:#999;font-size:13px;">Müşteri bulunamadı</div>';
        resultsEl.style.display = 'block';
        return;
    }

    resultsEl.innerHTML = matches.map(c => {
        const alreadySelected = window._selectedPushCustomers.find(s => s.phone === c.phone);
        const safePhone = (c.phone||'').replace(/'/g,"\\'");
        const safeName  = (c.name||'İsimsiz').replace(/'/g,"\\'");
        return `<div onclick="selectPushCustomer('${safePhone}','${safeName}')"
            data-phone="${c.phone||''}"
            data-tokens='${JSON.stringify(c.fcmTokenlar||c.fcmTokens||[])}'
            style="padding:10px 14px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #f5f5f5;${alreadySelected?'background:#fff3e0;':''}">
            <div>
                <div style="font-weight:700;font-size:13px;">${c.name||'İsimsiz'}</div>
                <div style="font-size:11px;color:#999;">${c.phone||''} · ${(c.fcmTokenlar||c.fcmTokens||[]).length} cihaz</div>
            </div>
            <div style="font-size:11px;color:${alreadySelected?'#e67e22':'#27ae60'};font-weight:700;">${alreadySelected?'✓ Seçili':'Seç'}</div>
        </div>`;
    }).join('');
    resultsEl.style.display = 'block';
}

window.selectPushCustomer = function selectPushCustomer(phone, name) {
    // Token'ları DOM'daki data attribute'dan oku
    const row = document.querySelector(`#push-customer-results [data-phone="${phone}"]`);
    let tokens = [];
    if(row) {
        try { tokens = JSON.parse(row.dataset.tokens || '[]'); } catch(_){}
    }
    // Fallback: cache'den oku (cache'i temizleme!)
    if(!tokens.length && window._allPushCustomers) {
        const found = window._allPushCustomers.find(c => c.phone === phone);
        if(found) tokens = found.fcmTokenlar || found.fcmTokens || [];
    }

    const already = window._selectedPushCustomers.findIndex(s => s.phone === phone);
    if(already >= 0) {
        window._selectedPushCustomers.splice(already, 1);
    } else {
        window._selectedPushCustomers.push({ phone, name, tokens });
    }
    renderSelectedCustomers();
    document.getElementById('push-customer-results').style.display = 'none';
    document.getElementById('push-phone').value = '';
    // Sonuç sayısını güncelle
    const countEl = document.getElementById('push-selected-count');
    if(countEl) countEl.innerText = window._selectedPushCustomers.length ? `${window._selectedPushCustomers.length} kişi seçildi` : '';
}

window.removeSelectedCustomer = function removeSelectedCustomer(phone) {
    window._selectedPushCustomers = window._selectedPushCustomers.filter(s => s.phone !== phone);
    renderSelectedCustomers();
}

window.renderSelectedCustomers = function renderSelectedCustomers() {
    const el = document.getElementById('push-selected-customers');
    const countEl = document.getElementById('push-selected-count');
    if(!window._selectedPushCustomers.length) {
        el.innerHTML = '';
        if(countEl) countEl.innerText = '';
        return;
    }
    el.innerHTML = window._selectedPushCustomers.map(c => {
        const tokenCount = (c.tokens||[]).length;
        const tokenBadge = tokenCount > 0
            ? `<span style="font-size:10px;background:#27ae60;color:white;border-radius:8px;padding:1px 5px;margin-left:2px;">${tokenCount} cihaz</span>`
            : `<span style="font-size:10px;background:#e74c3c;color:white;border-radius:8px;padding:1px 5px;margin-left:2px;">token yok</span>`;
        return `<div style="display:flex;align-items:center;gap:5px;background:#fff3e0;border:1px solid #ffe0b2;border-radius:20px;padding:4px 10px 4px 12px;font-size:12px;font-weight:600;">
            <span>${c.name||c.phone}</span>${tokenBadge}
            <span onclick="removeSelectedCustomer('${c.phone}')" style="cursor:pointer;color:#e67e22;font-size:16px;line-height:1;margin-left:2px;">×</span>
        </div>`;
    }).join('');
    const total = window._selectedPushCustomers.reduce((s,c)=>s+(c.tokens||[]).length, 0);
    if(countEl) countEl.innerText = `${window._selectedPushCustomers.length} kişi seçildi · toplam ${total} cihaz`;
}

window.sendBulkPush = async function sendBulkPush() {
    console.log('sendBulkPush çağrıldı, electronAPI:', !!window.electronAPI);
    if(!window.electronAPI) {
        showPushResult('❌ Bu özellik sadece Electron panelde çalışır!', false);
        return;
    }

    const title = document.getElementById('push-title').value.trim();
    const body  = document.getElementById('push-body').value.trim();
    const image = document.getElementById('push-image').value.trim();
    if(!title || !body) {
        showPushResult('⚠️ Başlık ve mesaj boş olamaz!', false);
        return;
    }

    // Aktif kategori butonuna bak (radio yerine güvenilir)
    const activecat = document.querySelector('.pcat-btn.pcat-active')?.id?.replace('pcat-','') || '';
    const target = activecat === 'manuel' ? 'single' : (document.querySelector('input[name="push-target"]:checked')?.value || 'all');
    const btn = document.getElementById('push-send-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Gönderiliyor...';

    try {
        let tokens = [];
        let snap;

        // Yardımcı: müşteriden token al
        const getTokens = (d) => (d.fcmTokenlar || d.fcmTokens || []).filter(Boolean);
        // Yardımcı: tarih dönüşümü
        const toDate = (v) => v?.toDate?.() || (v instanceof Date ? v : null);

        if(target === 'single') {
            const selected = window._selectedPushCustomers || [];
            if(!selected.length) { showPushResult('⚠️ En az bir müşteri seçin!', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }
            selected.forEach(c => tokens.push(...(c.tokens||[]).filter(Boolean)));
            if(!tokens.length) { showPushResult('⚠️ Seçilen müşterilerin kayıtlı cihazı (FCM token) yok. Bu müşteriler uygulamayı henüz PWA olarak yüklememişlerdir.', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }

        } else if(target === 'all') {
            snap = await getDocs(rc("customers"));
            snap.forEach(d => tokens.push(...getTokens(d.data())));

        } else if(target === 'recent7') {
            const cutoff = new Date(Date.now() - 7*24*60*60*1000);
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); const last=toDate(c.lastOrderDate); if(last && last>=cutoff) tokens.push(...getTokens(c)); });

        } else if(target === 'recent') {
            const cutoff = new Date(Date.now() - 30*24*60*60*1000);
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); const last=toDate(c.lastOrderDate); if(last && last>=cutoff) tokens.push(...getTokens(c)); });

        } else if(target === 'loyal') {
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); if((c.orderCount||0)>=30) tokens.push(...getTokens(c)); });

        } else if(target === 'passive') {
            const cutoff = new Date(Date.now() - 60*24*60*60*1000);
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); const last=toDate(c.lastOrderDate); if(last && last<cutoff) tokens.push(...getTokens(c)); });

        } else if(target === 'new') {
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); const cnt=c.orderCount||0; if(cnt>=1&&cnt<=3) tokens.push(...getTokens(c)); });

        } else if(target === 'product') {
            const productName = (document.getElementById('push-product-name')?.value||'').trim().toLowerCase();
            if(!productName) { showPushResult('⚠️ Ürün adı girin!', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }
            // Siparişlerde bu ürünü sipariş eden müşterileri bul
            const orderSnap = await getDocs(query(rc("orders"), where('status','==','Teslim Edildi')));
            const phones = new Set();
            orderSnap.forEach(d => {
                const o = d.data();
                if((o.items||[]).some(item => (item.n||item.name||'').toLowerCase().includes(productName))) phones.add(o.phone);
            });
            if(!phones.size) { showPushResult('⚠️ Bu ürünü sipariş eden müşteri bulunamadı!', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); if(phones.has(c.phone)) tokens.push(...getTokens(c)); });

        } else if(target === 'has-points') {
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); if((c.loyaltyPoints||c.points||0)>=100) tokens.push(...getTokens(c)); });

        } else if(target === 'no-points-used') {
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); const pts=c.loyaltyPoints||c.points||0; const used=c.pointsUsed||0; if(pts>0 && used===0) tokens.push(...getTokens(c)); });

        } else if(target === 'high-points') {
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); if((c.loyaltyPoints||c.points||0)>=500) tokens.push(...getTokens(c)); });

        } else if(target === 'neighborhood') {
            const hood = (document.getElementById('push-neighborhood')?.value||'').trim().toLowerCase();
            if(!hood) { showPushResult('⚠️ Mahalle adı girin!', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }
            snap = await getDocs(rc("customers"));
            snap.forEach(d => {
                const c=d.data();
                const addrs = (c.addresses||c.adresler||[]);
                const match = addrs.some(a => (a.adres||a.address||'').toLowerCase().includes(hood));
                if(match) tokens.push(...getTokens(c));
            });

        } else if(target === 'group') {
            const groupId = document.getElementById('push-group-select')?.value;
            if(!groupId) { showPushResult('⚠️ Grup seçin!', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }
            const groups = JSON.parse(localStorage.getItem('pushGroups')||'[]');
            const group = groups.find(g => g.id === groupId);
            if(!group) { showPushResult('❌ Grup bulunamadı!', false); btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder'; return; }
            snap = await getDocs(rc("customers"));
            snap.forEach(d => { const c=d.data(); if(group.phones.includes(c.phone)) tokens.push(...getTokens(c)); });
        }

        // Tekrar edenleri temizle
        tokens = [...new Set(tokens)].filter(Boolean);

        if(!tokens.length) {
            showPushResult('⚠️ Bu kritere uyan bildirim token\'ı bulunamadı!', false);
            btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Bildirimi Gönder';
            return;
        }

        // Electron FCM ile gönder (50'şer batch)
        let sent = 0;
        for(let i = 0; i < tokens.length; i += 50) {
            const batch = tokens.slice(i, i + 50);
            await window.electronAPI.sendFcmPush(batch, title, body, image || null);
            sent += batch.length;
        }

        showPushResult(`✅ ${sent} müşteriye bildirim gönderildi!`, true);
        document.getElementById('push-title').value = '';
        document.getElementById('push-body').value = '';
        document.getElementById('push-image').value = '';
        document.getElementById('push-img-preview').style.display = 'none';
        document.getElementById('push-char').textContent = '0';
        document.getElementById('prev-title').textContent = 'Başlık buraya gelecek';
        document.getElementById('prev-body').textContent = 'Mesaj buraya gelecek...';
        window._selectedPushCustomers = [];
        renderSelectedCustomers();

    } catch(e) {
        console.error('Bulk push hata:', e);
        showPushResult('❌ Hata: ' + e.message, false);
    }

    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-paper-plane"></i> Bildirimi Gönder';
}

