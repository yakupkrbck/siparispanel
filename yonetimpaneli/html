        <button onclick="copyOrderLink()" class="btn" style="background:#3498db;width:auto;padding:0 18px;height:40px;flex:none;font-size:13px;">
          <i class="fas fa-share-alt"></i> Linki Kopyala
        </button>
      </div>
    </div>

  </div>
</div>


<div id="contact-settings" class="tab">
  <h3 style="margin-bottom:6px;">📋 İletişim & Profil Ayarları</h3>
  <p style="font-size:13px;color:#7f8c8d;margin-bottom:24px;">Sipariş uygulamasında gösterilecek iletişim bilgileri, çalışma saatleri ve SEO ayarları.</p>
  <div style="max-width:700px;display:flex;flex-direction:column;gap:16px;">

    <!-- İletişim Bilgileri -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">📞 İletişim Bilgileri</h4>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="fg"><label>Telefon</label><input type="tel" id="ct-phone" placeholder="0222 246 61 20"></div>
        <div class="fg"><label>WhatsApp (0 ile başlayın)</label><input type="tel" id="ct-whatsapp" placeholder="05XX XXX XX XX"></div>
        <div class="fg" style="grid-column:1/-1"><label>Adres</label><input type="text" id="ct-address" placeholder="Atatürk Cad. No:1, Karacabey/Bursa"></div>
        <div class="fg" style="grid-column:1/-1"><label>Google Maps Linki</label><input type="text" id="ct-mapurl" placeholder="https://maps.app.goo.gl/..."></div>
      </div>
    </div>

    <!-- Sosyal Medya -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">📱 Sosyal Medya</h4>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="fg"><label>Instagram URL</label><input type="text" id="ct-instagram" placeholder="https://instagram.com/..."></div>
        <div class="fg"><label>Facebook URL</label><input type="text" id="ct-facebook" placeholder="https://facebook.com/..."></div>
        <div class="fg"><label>Twitter / X URL</label><input type="text" id="ct-twitter" placeholder="https://twitter.com/..."></div>
      </div>
    </div>

    <!-- Çalışma Saatleri -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">🕐 Çalışma Saatleri</h4>
      <div style="display:flex;flex-direction:column;gap:8px;" id="wh-rows"></div>
    </div>

    <!-- SEO -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">🔍 SEO Ayarları</h4>
      <div class="fg" style="margin-bottom:12px;"><label>Sayfa Başlığı (Title)</label><input type="text" id="ct-seo-title" placeholder="Dönerci İsmail | Online Sipariş" maxlength="60">
        <div style="font-size:11px;color:#aaa;margin-top:3px;" id="seo-title-count">0/60 karakter</div>
      </div>
      <div class="fg" style="margin-bottom:12px;"><label>Açıklama (Description)</label>
        <textarea id="ct-seo-desc" rows="3" placeholder="Karacabey'in en lezzetli döneri. Online sipariş ver, kapına gelsin." maxlength="160" style="resize:vertical;padding:9px;border:1px solid #ddd;border-radius:5px;font-size:13px;font-family:inherit;width:100%;"></textarea>
        <div style="font-size:11px;color:#aaa;margin-top:3px;" id="seo-desc-count">0/160 karakter</div>
      </div>
      <div class="fg"><label>Anahtar Kelimeler (virgülle ayırın)</label><input type="text" id="ct-seo-keywords" placeholder="döner, karacabey, online sipariş, fast food"></div>
    </div>

    <!-- Kaydet -->
    <button onclick="saveContactSettings()" class="btn" style="background:var(--primary);height:44px;font-size:14px;">💾 Tüm Ayarları Kaydet</button>
  </div>
</div>

<div id="printer-settings" class="tab">
  <h3 style="margin-bottom:6px;">🖨️ Yazıcı Ayarları</h3>
  <p style="font-size:13px;color:#7f8c8d;margin-bottom:20px;">Fiş boyutu, font, yazı kalınlığı ve şablon ayarlarını buradan yapın.</p>
  <div style="max-width:660px;display:flex;flex-direction:column;gap:16px;">

    <!-- KAĞIT & BOYUT -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">📄 Kağıt & Boyut</h4>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div class="fg" style="min-width:140px;">
          <label>Kağıt Genişliği</label>
          <select id="pr-width" onchange="savePrinterSettings()">
            <option value="76">80mm yazıcı (76mm)</option>
            <option value="56">58mm yazıcı (56mm)</option>
            <option value="70">70mm özel</option>
          </select>
        </div>
        <div class="fg" style="min-width:120px;">
          <label>Sayfa Kenar Boşluğu</label>
          <select id="pr-margin" onchange="savePrinterSettings()">
            <option value="1">1mm (sıkı)</option>
            <option value="2" selected>2mm (normal)</option>
            <option value="4">4mm (geniş)</option>
          </select>
        </div>
        <div class="fg" style="min-width:120px;">
          <label>Satır Aralığı</label>
          <select id="pr-lineheight" onchange="savePrinterSettings()">
            <option value="1.4">Sıkı (1.4)</option>
            <option value="1.55" selected>Normal (1.55)</option>
            <option value="1.75">Geniş (1.75)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- FONT & YAZICI -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">🔤 Font & Yazı</h4>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div class="fg" style="min-width:180px;">
          <label>Font Ailesi</label>
          <select id="pr-font" onchange="savePrinterSettings()">
            <option value="'Courier New',Courier,monospace" selected>Courier New (önerilen)</option>
            <option value="'Arial',sans-serif">Arial</option>
            <option value="'Roboto',sans-serif">Roboto</option>
            <option value="monospace">Sistem Monospace</option>
          </select>
        </div>
        <div class="fg" style="min-width:110px;">
          <label>Normal Yazı Boyutu</label>
          <select id="pr-fontsize" onchange="savePrinterSettings()">
            <option value="10">10px (küçük)</option>
            <option value="11">11px</option>
            <option value="12" selected>12px (normal)</option>
            <option value="13">13px</option>
            <option value="14">14px (büyük)</option>
          </select>
        </div>
        <div class="fg" style="min-width:110px;">
          <label>Ürün Yazı Kalınlığı</label>
          <select id="pr-itemweight" onchange="savePrinterSettings()">
            <option value="600">600 (normal)</option>
            <option value="700" selected>700 (kalın)</option>
            <option value="800">800 (çok kalın)</option>
            <option value="900">900 (maksimum)</option>
          </select>
        </div>
        <div class="fg" style="min-width:110px;">
          <label>Toplam Yazı Boyutu</label>
          <select id="pr-totalsize" onchange="savePrinterSettings()">
            <option value="13">13px</option>
            <option value="14">14px</option>
            <option value="15" selected>15px (normal)</option>
            <option value="17">17px (büyük)</option>
            <option value="19">19px (çok büyük)</option>
          </select>
        </div>
      </div>
      <div style="margin-top:12px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;">
          <input type="checkbox" id="pr-bold-info" onchange="savePrinterSettings()" style="width:16px;height:16px;accent-color:var(--primary);">
          Müşteri bilgisi kalın basılsın
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;">
          <input type="checkbox" id="pr-dark-total" onchange="savePrinterSettings()" checked style="width:16px;height:16px;accent-color:var(--primary);">
          Toplam satırı çift çizgili olsun
        </label>
      </div>
    </div>

    <!-- ŞABLON -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 16px;color:var(--dark);">📝 Fiş Şablonu</h4>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div class="fg" style="flex:2;min-width:180px;">
          <label>İşletme Adı (başlık)</label>
          <input type="text" id="pr-brand" value="DONERCI ISMAIL" oninput="savePrinterSettings()" style="font-weight:700;font-size:15px;letter-spacing:1px;">
        </div>
        <div class="fg" style="min-width:140px;">
          <label>Alt Başlık</label>
          <input type="text" id="pr-subtitle" value="KARACABEY" oninput="savePrinterSettings()">
        </div>
      </div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:4px;">
        <div class="fg" style="min-width:160px;">
          <label>Alt Bilgi Satır 1 (telefon)</label>
          <input type="text" id="pr-footer1" value="Tel: 0224 246 61 20" oninput="savePrinterSettings()">
        </div>
        <div class="fg" style="min-width:160px;">
          <label>Alt Bilgi Satır 2 (site)</label>
          <input type="text" id="pr-footer2" value="donercismail.com" oninput="savePrinterSettings()">
        </div>
        <div class="fg" style="min-width:140px;">
          <label>Kapanış Mesajı</label>
          <input type="text" id="pr-closing" value="Afiyet Olsun!" oninput="savePrinterSettings()">
        </div>
      </div>
      <div style="margin-top:12px;display:flex;gap:12px;flex-wrap:wrap;">
        <div class="fg" style="min-width:160px;">
          <label>Üst Etiket Metni</label>
          <input type="text" id="pr-tag" value="** ONLINE SIPARIS **" oninput="savePrinterSettings()">
        </div>
        <div class="fg" style="min-width:120px;">
          <label>Başlık Font Boyutu</label>
          <select id="pr-brandsize" onchange="savePrinterSettings()">
            <option value="15">15px</option>
            <option value="17" selected>17px (normal)</option>
            <option value="19">19px</option>
            <option value="22">22px (büyük)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ÖNZLEME & TEST -->
    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);border-left:4px solid #e67e22;">
      <h4 style="margin:0 0 8px;color:var(--dark);">🖨️ Test & Önizleme</h4>
      <p style="font-size:13px;color:#7f8c8d;margin:0 0 16px;">Ayarları kaydettikten sonra test adisyonu yazdırarak sonucu kontrol edin.</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button onclick="printTestReceipt()" class="btn" style="background:#e67e22;width:auto;padding:0 24px;height:40px;font-size:14px;">🖨️ Test Adisyonu Yazdır</button>
        <button onclick="showPrintPreview()" class="btn" style="background:#3498db;width:auto;padding:0 24px;height:40px;font-size:14px;">👁️ Önizle</button>
        <button onclick="resetPrinterSettings()" class="btn" style="background:#95a5a6;width:auto;padding:0 18px;height:40px;font-size:13px;">↺ Sıfırla</button>
      </div>
      <div id="print-preview-frame" style="display:none;margin-top:16px;border:2px dashed #ddd;border-radius:10px;padding:16px;background:#f9f9f9;">
        <div style="font-size:11px;color:#aaa;margin-bottom:10px;text-align:center;">── FİŞ ÖNİZLEME (ekran görünümü) ──</div>
        <div id="print-preview-content" style="font-family:'Courier New',monospace;font-size:12px;max-width:300px;margin:0 auto;background:white;padding:10px;border-radius:6px;box-shadow:0 2px 8px rgba(0,0,0,.08);"></div>
      </div>
    </div>

  </div>
</div>

<div id="vip-settings" class="tab">
  <h3 style="margin-bottom:6px;">🏆 VIP & Puan Ayarları</h3>
  <p style="font-size:13px;color:#7f8c8d;margin-bottom:20px;">Müşteri sadakat seviyelerini ve puan oranlarını buradan düzenleyin. Değişiklikler anında sonraki teslimlara yansır.</p>
  <div style="max-width:660px;display:flex;flex-direction:column;gap:16px;">

    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 6px;color:var(--dark);">🎖️ Rozet Seviyeleri & Puan Oranları</h4>
      <p style="font-size:12px;color:#aaa;margin:0 0 18px;">Son 30 gündeki <b>teslim edilen</b> sipariş sayısına göre seviye belirlenir.</p>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <div style="display:flex;align-items:center;gap:10px;background:#fff8f2;border-radius:10px;padding:13px 16px;border:1.5px solid #f5cba7;">
          <span style="font-size:24px;flex-shrink:0;">🥉</span>
          <div style="flex:1;"><div style="font-weight:700;font-size:13px;color:#a04000;">Bronz</div><div style="font-size:11px;color:#aaa;">Son 30 günde en az</div></div>
          <input type="number" id="vip-bronz-min" value="2" min="1" max="99" style="width:52px;text-align:center;padding:7px 4px;border:1.5px solid #ddd;border-radius:8px;font-weight:700;font-size:14px;">
          <span style="font-size:12px;color:#888;flex-shrink:0;">sipariş →</span>
          <input type="number" id="vip-bronz-rate" value="4" min="0" max="100" step="0.5" style="width:52px;text-align:center;padding:7px 4px;border:1.5px solid #cd7f32;border-radius:8px;font-weight:700;font-size:14px;color:#cd7f32;">
          <span style="font-size:12px;color:#888;flex-shrink:0;">%</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;background:#f8f8f8;border-radius:10px;padding:13px 16px;border:1.5px solid #bdc3c7;">
          <span style="font-size:24px;flex-shrink:0;">🥈</span>
          <div style="flex:1;"><div style="font-weight:700;font-size:13px;color:#5d6d7e;">Gümüş</div><div style="font-size:11px;color:#aaa;">Son 30 günde en az</div></div>
          <input type="number" id="vip-gumus-min" value="4" min="1" max="99" style="width:52px;text-align:center;padding:7px 4px;border:1.5px solid #ddd;border-radius:8px;font-weight:700;font-size:14px;">
          <span style="font-size:12px;color:#888;flex-shrink:0;">sipariş →</span>
          <input type="number" id="vip-gumus-rate" value="7" min="0" max="100" step="0.5" style="width:52px;text-align:center;padding:7px 4px;border:1.5px solid #95a5a6;border-radius:8px;font-weight:700;font-size:14px;color:#7f8c8d;">
          <span style="font-size:12px;color:#888;flex-shrink:0;">%</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;background:#fffde7;border-radius:10px;padding:13px 16px;border:1.5px solid #f9ca24;">
          <span style="font-size:24px;flex-shrink:0;">🥇</span>
          <div style="flex:1;"><div style="font-weight:700;font-size:13px;color:#b7950b;">Altın</div><div style="font-size:11px;color:#aaa;">Son 30 günde en az</div></div>
          <input type="number" id="vip-altin-min" value="8" min="1" max="99" style="width:52px;text-align:center;padding:7px 4px;border:1.5px solid #ddd;border-radius:8px;font-weight:700;font-size:14px;">
          <span style="font-size:12px;color:#888;flex-shrink:0;">sipariş →</span>
          <input type="number" id="vip-altin-rate" value="10" min="0" max="100" step="0.5" style="width:52px;text-align:center;padding:7px 4px;border:1.5px solid #f9ca24;border-radius:8px;font-weight:700;font-size:14px;color:#b7950b;">
          <span style="font-size:12px;color:#888;flex-shrink:0;">%</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;background:#fafafa;border-radius:10px;padding:13px 16px;border:1.5px dashed #eee;opacity:0.65;">
          <span style="font-size:24px;flex-shrink:0;">👤</span>
          <div style="flex:1;"><div style="font-weight:700;font-size:13px;color:#bbb;">Normal</div><div style="font-size:11px;color:#ccc;">Eşiklerin altında kalanlar</div></div>
          <span style="font-weight:700;color:#ccc;font-size:14px;">%0 — Puan yok</span>
        </div>
      </div>
      <button onclick="saveVipSettings()" class="btn" style="margin-top:16px;background:var(--primary);width:auto;padding:0 28px;height:40px;">💾 Kaydet</button>
    </div>

    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <h4 style="margin:0 0 6px;color:var(--dark);">🎁 Puan Kullanım Oranı</h4>
      <p style="font-size:12px;color:#aaa;margin:0 0 16px;">Müşteri kaç puan biriktirince kaç TL indirim kazanır?</p>
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <input type="number" id="vip-pts-goal" value="50" min="1" style="width:72px;text-align:center;padding:9px;border:1.5px solid #ddd;border-radius:8px;font-weight:700;font-size:16px;">
        <span style="font-size:15px;color:#555;font-weight:600;">puan =</span>
        <input type="number" id="vip-reward-tl" value="20" min="1" style="width:72px;text-align:center;padding:9px;border:1.5px solid var(--primary);border-radius:8px;font-weight:700;font-size:16px;color:var(--primary);">
        <span style="font-size:15px;color:#555;font-weight:600;">TL indirim</span>
      </div>
      <button onclick="saveVipSettings()" class="btn" style="margin-top:16px;background:var(--primary);width:auto;padding:0 28px;height:40px;">💾 Kaydet</button>
    </div>

    <div style="background:white;border-radius:14px;padding:22px;box-shadow:0 2px 10px rgba(0,0,0,.07);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
        <h4 style="margin:0;color:var(--dark);">📊 VIP Müşteri Dağılımı</h4>
        <button onclick="loadVipStats()" class="btn" style="background:#95a5a6;width:auto;padding:0 14px;font-size:12px;height:32px;">🔄 Yenile</button>
      </div>
      <div id="vip-stats"><div style="color:#aaa;font-size:13px;">Sekme açılınca otomatik yüklenir.</div></div>
    </div>

  </div>
</div>

</main>

</body>
</html>
