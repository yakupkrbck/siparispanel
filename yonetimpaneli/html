window.deleteCustomer=async(id,name)=>{
  const confirmed = await showConfirmDialog(`"${name}" adlı müşteriyi silmek istediğinize emin misiniz?\n\nBu işlem geri alınamaz.`);
  if(!confirmed) return;
  try{
    await deleteDoc(rds("customers",id));
    toast(`✅ ${name} silindi`);
    fetchCustomers();
  }catch(e){ toast("❌ Silme hatası: "+e.message,true); }
};
window.openEditCust=async id=>{
  try{
    const snap=await getDoc(rds("customers",id)); 
    if(!snap.exists()){ toast("❌ Müşteri bulunamadı",true); return; }
    const d=snap.data();
    document.getElementById('cust-edit-id').value=id; document.getElementById('cust-name').value=d.name||''; document.getElementById('cust-phone').value=d.phone||id; document.getElementById('cust-addr').value=d.addresses?.[0]?.address||d.address||''; document.getElementById('cust-pin').value=''; document.getElementById('cust-blacklist').value=String(d.blacklist||false); document.getElementById('cust-points').value=d.loyaltyPoints||d.points||0;
    document.getElementById('cust-modal-title').innerHTML=`👤 Müşteri Düzenle <button class="modal-close" onclick="closeModal('cust-modal')">×</button>`;
    loadCustOrdersInModal(d.phone||id); openModal('cust-modal');
  }catch(e){ toast("❌ Müşteri açılamadı: "+e.message,true); }
};
async function loadCustOrdersInModal(phone){
  const el=document.getElementById('cust-orders'); el.innerHTML='<div style="color:#999;font-size:13px;">Yükleniyor...</div>';
  try{
    const q=query(rc("orders"),where("phone","==",phone)); const snap=await getDocs(q);
    if(snap.empty){ el.innerHTML='<div style="color:#aaa;font-size:13px;">Sipariş yok.</div>'; return; }
    const orders=snap.docs.map(d=>d.data()).sort((a,b)=>(b.date?.seconds||0)-(a.date?.seconds||0));
    el.innerHTML=orders.map(o=>`<div style="padding:8px;border:1px solid #eee;border-radius:8px;margin-bottom:6px;font-size:12px;"><div style="display:flex;justify-content:space-between;font-weight:700;"><span>${new Date((o.date?.seconds||0)*1000).toLocaleString('tr-TR')}</span><span style="color:var(--primary);">${o.total} TL</span></div><div style="color:#666;margin-top:3px;">${(o.items||[]).map(i=>i.n).join(', ')}</div><span style="font-size:11px;background:#eee;padding:2px 8px;border-radius:10px;margin-top:4px;display:inline-block;">${o.status}</span></div>`).join('');
  }catch(e){ el.innerHTML='<div style="color:red;font-size:13px;">Hata.</div>'; }
}
window.saveCust=async()=>{
  const id=document.getElementById('cust-edit-id').value, name=document.getElementById('cust-name').value, addr=document.getElementById('cust-addr').value, pin=document.getElementById('cust-pin').value, bl=document.getElementById('cust-blacklist').value==='true', pts=parseInt(document.getElementById('cust-points').value)||0;
  const upd={name,blacklist:bl,loyaltyPoints:pts}; if(addr) upd.addresses=[{label:'Ev',address:addr}]; if(pin&&pin.length===4) upd.pin=pin;
  try{ await setDoc(rds("customers",id),upd,{merge:true}); toast("Müşteri güncellendi ✅"); closeModal('cust-modal'); fetchCustomers(); }catch(e){ toast("❌ Hata: "+e.message); }
};

