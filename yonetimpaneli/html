let _customersUnsubscribe = null;
async function fetchCustomers(){
  const tbody=document.getElementById('cust-body');
  tbody.innerHTML='<tr><td colspan="8" style="text-align:center;padding:20px;">Yükleniyor...</td></tr>';
  
  // Önceki listener varsa kapat
  if(_customersUnsubscribe){ _customersUnsubscribe(); _customersUnsubscribe=null; }
  
  try{
    // users koleksiyonunu tek seferlik al
    const usSnap = { forEach: () => {} }; // multi-tenant: tüm müşteriler customers altında
    
    // phone_customers'ı gerçek zamanlı dinle
    _customersUnsubscribe = onSnapshot(rc("customers"), phSnap => {
      const seen=new Set(); allCustomers=[];
      const proc=d=>{
        const data=d.data(); const phone=data.phoneNumber||data.phone||d.id||'-';
        if(seen.has(phone)) return; seen.add(phone);
        let addr='-';
        if(data.addresses?.length>0) addr=data.addresses[0].address||data.addresses[0].details||'-';
        else addr=data.details||data.address||data.adres||'-';
        allCustomers.push({id:d.id,name:data.fullName||data.name||'İsimsiz',phone,address:addr,pin:data.pin||data.password||'-',blacklist:data.blacklist||false,points:data.loyaltyPoints||data.points||0,orderCount:data.orderCount||0,lastOrderDate:data.lastOrderDate||null,onlineAt:data.onlineAt||null,tokenCount:(data.fcmTokenlar||data.fcmTokens||[]).filter(Boolean).length,notifPermission:data.notifPermission||null});
      };
      phSnap.forEach(proc); usSnap.forEach(proc); renderCustomers(allCustomers);
    });
  }catch(e){ tbody.innerHTML=`<tr><td colspan="8" style="color:red;text-align:center;">Hata: ${e.message}</td></tr>`; }
}
function renderCustomers(list){
  // VIP eşiklerini localStorage cache'den al (loadVipSettings çalıştıktan sonra dolar)
  let vipLevels = {bronz:2, gumus:4, altin:8};
  try { const cached = localStorage.getItem('vipLevels'); if(cached) vipLevels = JSON.parse(cached); } catch(_){}

  // Token istatistiklerini güncelle
  const tokenOk      = list.filter(u => (u.tokenCount||0) > 0).length;
  const tokenMissing = list.filter(u => (u.tokenCount||0) === 0 && u.notifPermission !== 'denied').length;
  const tokenDenied  = list.filter(u => u.notifPermission === 'denied').length;
  const totalDevices = list.reduce((s,u) => s + (u.tokenCount||0), 0);
  const setEl = (id, val) => { const el = document.getElementById(id); if(el) el.textContent = val; };
  setEl('token-stat-ok',      tokenOk);
  setEl('token-stat-missing', tokenMissing);
  setEl('token-stat-denied',  tokenDenied);
  setEl('token-stat-devices', totalDevices);

  const tbody=document.getElementById('cust-body');
  if(!list.length){ tbody.innerHTML='<tr><td colspan="8" style="text-align:center;padding:20px;">Müşteri bulunamadı.</td></tr>'; return; }
  tbody.innerHTML=list.map(u=>{
    let segment=''; const orderCount=u.orderCount||0; let lastOrderDays=999;
    if(u.lastOrderDate){ const lastDate=u.lastOrderDate.toDate?u.lastOrderDate.toDate():new Date(u.lastOrderDate.seconds*1000); lastOrderDays=Math.floor((new Date()-lastDate)/86400000); }
    
    // VIP rozeti — orderCount'a göre (tam doğru olan son 30 gün ama orderCount yaklaşık)
    if(orderCount >= vipLevels.altin)
      segment='<span style="background:linear-gradient(135deg,#f9ca24,#b7950b);color:white;font-size:9px;padding:2px 7px;border-radius:8px;font-weight:bold;margin-left:4px;">🥇 Altın</span>';
    else if(orderCount >= vipLevels.gumus)
      segment='<span style="background:linear-gradient(135deg,#bdc3c7,#7f8c8d);color:white;font-size:9px;padding:2px 7px;border-radius:8px;font-weight:bold;margin-left:4px;">🥈 Gümüş</span>';
    else if(orderCount >= vipLevels.bronz)
      segment='<span style="background:linear-gradient(135deg,#e59866,#cd7f32);color:white;font-size:9px;padding:2px 7px;border-radius:8px;font-weight:bold;margin-left:4px;">🥉 Bronz</span>';
    else if(lastOrderDays>30&&orderCount>0)
      segment='<span style="background:#95a5a6;color:white;font-size:9px;padding:2px 6px;border-radius:8px;font-weight:bold;margin-left:4px;">😴 Kayıp</span>';
    // Online göstergesi — son 1 dakika içinde onlineAt varsa
    const now = new Date();
    let onlineBadge = '';
    if(u.onlineAt) {
      const onlineDate = u.onlineAt.toDate ? u.onlineAt.toDate() : new Date(u.onlineAt.seconds*1000);
      const diffMin = (now - onlineDate) / 60000;
      if(diffMin < 1) onlineBadge = '<span style="background:#27ae60;color:white;font-size:9px;padding:2px 6px;border-radius:8px;font-weight:bold;margin-left:4px;">🟢 Online</span>';
    }
    // Profil fotoğrafı
    const photoHTML = u.photoURL
      ? `<img src="${u.photoURL}" style="width:32px;height:32px;border-radius:50%;object-fit:cover;margin-right:8px;vertical-align:middle;border:2px solid #eee;">`
      : `<span style="display:inline-flex;width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#FF6600,#CC5200);color:white;align-items:center;justify-content:center;font-size:13px;font-weight:800;margin-right:8px;vertical-align:middle;">${(u.name||'?')[0].toUpperCase()}</span>`;
    return `<tr style="${u.blacklist?'background:#fff5f5;':''}">
      <td style="display:flex;align-items:center;">${photoHTML}<div><b>${u.name}</b>${segment}${onlineBadge}${u.blacklist?'<br><span class="blacklist-badge">⛔ KARA LİSTE</span>':''}</div></td>
      <td>${u.phone}</td>
      <td><code style="background:#f0f0f0;padding:3px 8px;border-radius:4px;font-weight:700;">${u.pin||'—'}</code></td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${u.address}</td>
      <td>${u.points>0?`<span class="points-badge">🪙 ${u.points} puan</span>`:`<span style="color:#bbb;font-size:12px;">0 puan</span>`}</td>
      <td>${u.tokenCount > 0
        ? `<span style="background:#e8f8f5;color:#27ae60;font-size:11px;font-weight:700;padding:3px 9px;border-radius:10px;border:1px solid #d4efdf;">📲 ${u.tokenCount} cihaz</span>`
        : u.notifPermission === 'denied'
          ? '<span style="background:#fdedec;color:#c0392b;font-size:11px;font-weight:700;padding:3px 9px;border-radius:10px;border:1px solid #fadbd8;">🚫 Reddetti</span>'
          : '<span style="background:#fef9e7;color:#e67e22;font-size:11px;font-weight:700;padding:3px 9px;border-radius:10px;border:1px solid #fdebd0;">⚠️ Token yok</span>'
      }</td>
      <td>${u.blacklist?'<span style="color:#c0392b;font-weight:700;">⛔ Engelli</span>':'<span style="color:#27ae60;font-weight:700;">✅ Normal</span>'}</td>
      <td><div style="display:flex;gap:5px;">
        <button onclick="openEditCust('${u.id}')" class="btn" style="background:#e67e22;width:auto;padding:5px 10px;font-size:12px;"><i class="fas fa-edit"></i></button>
        <a href="https://wa.me/90${u.phone.replace(/^0/,'')}" target="_blank" class="btn" style="background:#25D366;width:auto;padding:5px 10px;font-size:12px;text-decoration:none;display:inline-flex;align-items:center;"><i class="fab fa-whatsapp"></i></a>
        <button onclick="deleteCustomer('${u.id}','${u.name.replace(/'/g,"\\'")}')" class="btn" style="background:#e74c3c;width:auto;padding:5px 10px;font-size:12px;"><i class="fas fa-trash"></i></button>
      </div></td></tr>`;
  }).join('');
}
